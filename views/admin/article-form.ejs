<%# Admin Article Create / Edit Form %>
<%
  const isEdit = article !== null;
  const formAction = isEdit ? `/admin/articles/edit/${article.id}` : '/admin/articles/new';
  const pageHeading = isEdit ? 'Edit Article' : 'New Article';

  /* Format existing published_at for datetime-local input (YYYY-MM-DDTHH:mm) */
  let publishedAtValue = '';
  if (isEdit && article.published_at) {
    const d = new Date(article.published_at);
    const pad = n => String(n).padStart(2, '0');
    publishedAtValue = `${d.getFullYear()}-${pad(d.getMonth()+1)}-${pad(d.getDate())}T${pad(d.getHours())}:${pad(d.getMinutes())}`;
  }
%>

<div class="admin-page">

  <!-- ========== PAGE HEADER ========== -->
  <div class="admin-page-header">
    <div>
      <h1 class="admin-page-title"><%= pageHeading %></h1>
      <% if (isEdit) { %>
        <p class="admin-page-subtitle">Editing: <span class="admin-page-slug">/blog/<%= article.slug %>/</span></p>
      <% } else { %>
        <p class="admin-page-subtitle">Slug will be auto-generated from the title</p>
      <% } %>
    </div>
    <div style="display:flex;gap:0.75rem;align-items:center;">
      <% if (isEdit) { %>
        <a href="/blog/<%= article.slug %>/" target="_blank" class="admin-btn admin-btn--ghost" rel="noopener">
          View Live &rarr;
        </a>
      <% } %>
      <a href="/admin/articles" class="admin-btn admin-btn--ghost">
        &larr; Back
      </a>
    </div>
  </div>

  <!-- ========== FLASH ========== -->
  <% if (typeof flash !== 'undefined' && flash) { %>
  <div class="admin-alert admin-alert--<%= flash.type %>" role="alert"><%= flash.message %></div>
  <% } %>

  <!-- ========== ARTICLE FORM ========== -->
  <form action="<%= formAction %>" method="POST" class="admin-article-form" id="articleForm">

    <div class="admin-form-layout">

      <!-- ========== MAIN FIELDS ========== -->
      <div class="admin-form-main">

        <!-- Title -->
        <div class="admin-form-group">
          <label for="title" class="admin-form-label admin-form-label--required">Title</label>
          <input
            type="text"
            id="title"
            name="title"
            class="admin-form-input admin-form-input--lg"
            placeholder="Article title..."
            value="<%= isEdit ? article.title : '' %>"
            required
            maxlength="255"
          >
        </div>

        <!-- Summary -->
        <div class="admin-form-group">
          <label for="summary" class="admin-form-label">Summary <span class="admin-form-hint">(shown in listings, used as meta description)</span></label>
          <textarea
            id="summary"
            name="summary"
            class="admin-form-textarea"
            rows="3"
            placeholder="A short summary of the article (120–160 characters recommended)..."
            maxlength="500"
          ><%= isEdit ? (article.summary || '') : '' %></textarea>
        </div>

        <!-- Content (Quill rich text editor) -->
        <div class="admin-form-group">
          <label class="admin-form-label admin-form-label--required">Content</label>

          <!-- Quill toolbar + editor mount point -->
          <div id="quill-editor" class="admin-quill-editor"></div>

          <!-- Hidden textarea — actual POST field, filled by JS before submit -->
          <textarea
            id="article-content"
            name="content"
            style="display:none"
            aria-hidden="true"
          ><%= isEdit ? (article.content || '') : '' %></textarea>

          <!-- Word count display -->
          <div class="admin-word-count" id="wordCountDisplay">
            <span id="wordCountNum">0</span> words &middot; est. <span id="readTimeNum">0</span> min read
          </div>

          <!-- SVG Insert trigger -->
          <div style="margin-top:0.5rem;display:flex;align-items:center;gap:0.5rem;flex-wrap:wrap;">
            <button type="button" id="svgContentTrigger" class="admin-btn admin-btn--ghost admin-btn--sm">
              Insert SVG
            </button>
            <span class="admin-form-hint" style="margin:0;">Paste raw SVG code to embed vector graphics inline.</span>
          </div>

          <!-- SVG Insert Panel (hidden by default) -->
          <div id="svgContentPanel" style="display:none;margin-top:0.75rem;border:1px solid var(--border);border-radius:var(--radius);padding:1rem;background:var(--surface);">
            <div style="display:flex;justify-content:space-between;align-items:center;margin-bottom:0.5rem;">
              <strong style="font-size:0.875rem;">Paste SVG Code</strong>
              <button type="button" id="svgContentCancel" class="admin-btn admin-btn--ghost admin-btn--sm">Cancel</button>
            </div>
            <textarea
              id="svgContentCode"
              class="admin-form-textarea"
              rows="8"
              placeholder='<svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 100 100">...</svg>'
              style="font-family:monospace;font-size:0.8125rem;"
            ></textarea>
            <div style="margin-top:0.5rem;display:flex;gap:0.5rem;align-items:center;">
              <button type="button" id="svgContentInsert" class="admin-btn admin-btn--primary admin-btn--sm">Insert into Article</button>
              <span id="svgContentError" style="color:var(--error);font-size:0.8125rem;display:none;">Invalid SVG. Must start with &lt;svg</span>
            </div>
          </div>

          <p class="admin-form-hint admin-form-hint--block" style="margin-top:0.5rem;">
            Use the toolbar for formatting and images (URL). Use Insert SVG for vector graphics. Headings (H2/H3) get anchor IDs for the Table of Contents automatically.
          </p>
        </div>

      </div>

      <!-- ========== SIDEBAR FIELDS ========== -->
      <aside class="admin-form-sidebar">

        <!-- Status & Publish -->
        <div class="admin-sidebar-card">
          <h3 class="admin-sidebar-card__title">Publish</h3>
          <div class="admin-form-group">
            <label for="status" class="admin-form-label">Status</label>
            <select id="status" name="status" class="admin-select">
              <option value="published" <%= !isEdit || article.status === 'published' ? 'selected' : '' %>>Published</option>
              <option value="draft" <%= isEdit && article.status === 'draft' ? 'selected' : '' %>>Draft</option>
            </select>
          </div>
          <div class="admin-form-group">
            <label for="published_at" class="admin-form-label">Publish Date</label>
            <input
              type="datetime-local"
              id="published_at"
              name="published_at"
              class="admin-form-input"
              value="<%= publishedAtValue %>"
            >
            <p class="admin-form-hint">Leave blank to use current time when publishing</p>
          </div>
          <button type="submit" class="admin-btn admin-btn--primary admin-btn--full">
            <%= isEdit ? 'Update Article' : 'Publish Article' %>
          </button>
        </div>

        <!-- Category -->
        <div class="admin-sidebar-card">
          <h3 class="admin-sidebar-card__title">Category</h3>
          <div class="admin-form-group">
            <select id="category_id" name="category_id" class="admin-select">
              <option value="">— No Category —</option>
              <% categories.forEach(function(cat) { %>
                <option value="<%= cat.id %>" <%= isEdit && article.category_id == cat.id ? 'selected' : '' %>>
                  <%= cat.name %>
                </option>
              <% }); %>
            </select>
          </div>
        </div>

        <!-- Tags -->
        <div class="admin-sidebar-card">
          <h3 class="admin-sidebar-card__title">Tags</h3>
          <div class="admin-form-group">
            <input
              type="text"
              id="tags"
              name="tags"
              class="admin-form-input"
              placeholder="e.g. Node.js, AI, Web Dev"
              value="<%= isEdit ? (article.tags || '') : '' %>"
              maxlength="500"
            >
            <p class="admin-form-hint">Comma-separated</p>
          </div>
        </div>

        <!-- Thumbnail -->
        <div class="admin-sidebar-card">
          <h3 class="admin-sidebar-card__title">Thumbnail</h3>

          <!-- Thumbnail mode tabs -->
          <div style="display:flex;gap:0;border:1px solid var(--border);border-radius:var(--radius);overflow:hidden;margin-bottom:0.75rem;">
            <button type="button" id="thumbModeUrl" class="admin-btn admin-btn--ghost admin-btn--sm" style="flex:1;border-radius:0;border:none;border-right:1px solid var(--border);background:var(--accent);color:#fff;font-weight:600;">Image URL</button>
            <button type="button" id="thumbModeSvg" class="admin-btn admin-btn--ghost admin-btn--sm" style="flex:1;border-radius:0;border:none;">SVG Code</button>
          </div>

          <!-- URL mode -->
          <div id="thumbUrlMode" class="admin-form-group">
            <input
              type="text"
              id="thumbnail"
              name="thumbnail"
              class="admin-form-input"
              placeholder="https://... or /images/blog/my-image.jpg"
              value="<%= isEdit ? (article.thumbnail || '') : '' %>"
              maxlength="65535"
            >
            <p class="admin-form-hint">Full URL or relative path to an image file.</p>
          </div>

          <!-- SVG Code mode -->
          <div id="thumbSvgMode" class="admin-form-group" style="display:none;">
            <textarea
              id="thumbSvgCode"
              class="admin-form-textarea"
              rows="7"
              placeholder='<svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 1200 630">...</svg>'
              style="font-family:monospace;font-size:0.8125rem;"
            ></textarea>
            <p class="admin-form-hint">Paste SVG code. It will be stored as a data URI thumbnail.</p>
            <button type="button" id="thumbSvgApply" class="admin-btn admin-btn--primary admin-btn--sm" style="margin-top:0.5rem;">Apply SVG as Thumbnail</button>
            <span id="thumbSvgError" style="color:var(--error);font-size:0.8125rem;display:none;margin-left:0.5rem;">Invalid SVG.</span>
          </div>

          <!-- Live thumbnail preview -->
          <div id="thumbPreviewWrap" style="display:none;margin-top:0.75rem;">
            <img id="thumbPreview" src="" alt="thumbnail preview" style="width:100%;border-radius:8px;border:1px solid var(--border);object-fit:cover;max-height:160px;">
          </div>
        </div>

        <!-- Author -->
        <div class="admin-sidebar-card">
          <h3 class="admin-sidebar-card__title">Author</h3>
          <div class="admin-form-group">
            <input
              type="text"
              id="author"
              name="author"
              class="admin-form-input"
              value="<%= isEdit ? (article.author || 'Value.Codes') : 'Value.Codes' %>"
              maxlength="100"
            >
          </div>
        </div>

        <!-- SEO — Industry Grade -->
        <div class="admin-sidebar-card">
          <h3 class="admin-sidebar-card__title">SEO</h3>

          <!-- Focus Keyword -->
          <div class="admin-form-group">
            <label for="focus_keyword" class="admin-form-label">Focus Keyword <span class="admin-form-hint">(optional)</span></label>
            <input
              type="text"
              id="focus_keyword"
              name="focus_keyword"
              class="admin-form-input"
              placeholder="e.g. javascript performance"
              value="<%= isEdit ? (article.focus_keyword || '') : '' %>"
              maxlength="100"
            >
            <p class="admin-form-hint">Primary keyword this article targets</p>
          </div>

          <!-- Meta Title with counter -->
          <div class="admin-form-group">
            <div class="admin-seo-label-row">
              <label for="meta_title" class="admin-form-label">Meta Title</label>
              <span class="admin-char-counter" id="metaTitleCounter">0/60</span>
            </div>
            <input
              type="text"
              id="meta_title"
              name="meta_title"
              class="admin-form-input"
              placeholder="Leave blank to use article title"
              value="<%= isEdit ? (article.meta_title || '') : '' %>"
              maxlength="255"
            >
            <div class="admin-char-bar"><div class="admin-char-bar__fill" id="metaTitleBar"></div></div>
          </div>

          <!-- Meta Description with counter -->
          <div class="admin-form-group">
            <div class="admin-seo-label-row">
              <label for="meta_description" class="admin-form-label">Meta Description</label>
              <span class="admin-char-counter" id="metaDescCounter">0/160</span>
            </div>
            <textarea
              id="meta_description"
              name="meta_description"
              class="admin-form-textarea"
              rows="3"
              placeholder="Leave blank to use summary (120–160 chars)"
              maxlength="300"
            ><%= isEdit ? (article.meta_description || '') : '' %></textarea>
            <div class="admin-char-bar"><div class="admin-char-bar__fill" id="metaDescBar"></div></div>
          </div>

          <!-- SERP Preview -->
          <div class="admin-serp-preview" id="serpPreview">
            <div class="admin-serp-preview__label">Google Preview</div>
            <div class="admin-serp-preview__url" id="serpUrl">value.codes › blog › slug</div>
            <div class="admin-serp-preview__title" id="serpTitle">Article Title — Value.Codes</div>
            <div class="admin-serp-preview__desc" id="serpDesc">Meta description will appear here...</div>
          </div>

          <!-- Social Preview (collapsible) -->
          <div class="admin-social-preview">
            <button type="button" class="admin-social-preview__toggle" id="socialToggle" aria-expanded="false">
              <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M4 12v8a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2v-8"/><polyline points="16 6 12 2 8 6"/><line x1="12" y1="2" x2="12" y2="15"/></svg>
              Preview Social Card
            </button>
            <div class="admin-social-preview__panel" id="socialPanel" hidden>
              <div class="admin-social-card" id="socialCard">
                <div class="admin-social-card__image" id="socialImage">
                  <span>No thumbnail set</span>
                </div>
                <div class="admin-social-card__body">
                  <div class="admin-social-card__domain">value.codes</div>
                  <div class="admin-social-card__title" id="socialTitle">Article title will appear here</div>
                  <div class="admin-social-card__desc" id="socialDesc">Description will appear here</div>
                </div>
              </div>
            </div>
          </div>
        </div>

      </aside>
    </div>

  </form>

</div>

<!-- Quill CSS (snow theme) -->
<link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/quill@2/dist/quill.snow.css">

<!-- Quill JS -->
<script src="https://cdn.jsdelivr.net/npm/quill@2/dist/quill.js"></script>

<script>
(function () {

  /* ── Quill setup ── */
  const toolbarOptions = [
    [{ header: [1, 2, 3, 4, false] }],
    ['bold', 'italic', 'underline', 'strike'],
    [{ color: [] }, { background: [] }],
    [{ list: 'ordered' }, { list: 'bullet' }],
    [{ indent: '-1' }, { indent: '+1' }],
    [{ align: [] }],
    ['blockquote', 'code-block'],
    ['link', 'image'],
    ['clean']
  ];

  const quill = new Quill('#quill-editor', {
    theme: 'snow',
    placeholder: 'Write your article content here...',
    modules: {
      toolbar: {
        container: toolbarOptions,
        handlers: {
          /* Override default image handler — insert via URL instead of base64 */
          image: function () {
            const url = window.prompt('Image URL (paste a full https:// URL):');
            if (url && url.trim()) {
              const range = quill.getSelection(true);
              quill.insertEmbed(range.index, 'image', url.trim());
              quill.setSelection(range.index + 1);
            }
          }
        }
      }
    }
  });

  /* ── Pre-fill existing content when editing ── */
  const hiddenInput = document.getElementById('article-content');
  const existingHTML = hiddenInput.value.trim();
  if (existingHTML) {
    quill.clipboard.dangerouslyPasteHTML(existingHTML);
  }

  /* ── On submit: copy Quill HTML → hidden textarea ── */
  const form = document.getElementById('articleForm');
  form.addEventListener('submit', function () {
    hiddenInput.value = quill.getSemanticHTML();
  });

  /* ── Word count & read time ── */
  function updateWordCount() {
    const text = quill.getText().trim();
    const words = text ? text.split(/\s+/).filter(Boolean).length : 0;
    const minutes = Math.max(1, Math.ceil(words / 200));
    document.getElementById('wordCountNum').textContent = words.toLocaleString();
    document.getElementById('readTimeNum').textContent = minutes;
  }
  quill.on('text-change', updateWordCount);
  updateWordCount();

  /* ── Thumbnail preview ── */
  const thumbInput = document.getElementById('thumbnail');
  const thumbWrap  = document.getElementById('thumbPreviewWrap');
  const thumbImg   = document.getElementById('thumbPreview');

  function updateThumbPreview() {
    const val = thumbInput.value.trim();
    if (val) {
      thumbImg.src = val;
      thumbWrap.style.display = 'block';
      thumbImg.onerror = function() { thumbWrap.style.display = 'none'; };
      thumbImg.onload  = function() { thumbWrap.style.display = 'block'; };
    } else {
      thumbWrap.style.display = 'none';
    }
  }
  thumbInput.addEventListener('input', updateThumbPreview);
  updateThumbPreview(); /* Show preview on load when editing */

  /* ── Thumbnail mode tabs (URL / SVG Code) ── */
  const thumbModeUrl  = document.getElementById('thumbModeUrl');
  const thumbModeSvg  = document.getElementById('thumbModeSvg');
  const thumbUrlMode  = document.getElementById('thumbUrlMode');
  const thumbSvgMode  = document.getElementById('thumbSvgMode');
  const thumbSvgCode  = document.getElementById('thumbSvgCode');
  const thumbSvgApply = document.getElementById('thumbSvgApply');
  const thumbSvgError = document.getElementById('thumbSvgError');

  /* Detect if current thumbnail is an SVG data URI — switch to SVG mode on load */
  (function initThumbMode() {
    const current = thumbInput.value.trim();
    if (current.startsWith('data:image/svg+xml')) {
      activateThumbSvgMode();
      /* Decode the data URI back to SVG code for editing */
      try {
        const raw = current.replace(/^data:image\/svg\+xml;charset=utf-8,/, '');
        thumbSvgCode.value = decodeURIComponent(raw);
      } catch (e) { /* leave blank if decode fails */ }
    }
  })();

  function activateThumbUrlMode() {
    thumbModeUrl.style.background = 'var(--accent)';
    thumbModeUrl.style.color = '#fff';
    thumbModeUrl.style.fontWeight = '600';
    thumbModeSvg.style.background = '';
    thumbModeSvg.style.color = '';
    thumbModeSvg.style.fontWeight = '';
    thumbUrlMode.style.display = '';
    thumbSvgMode.style.display = 'none';
    thumbSvgError.style.display = 'none';
  }

  function activateThumbSvgMode() {
    thumbModeSvg.style.background = 'var(--accent)';
    thumbModeSvg.style.color = '#fff';
    thumbModeSvg.style.fontWeight = '600';
    thumbModeUrl.style.background = '';
    thumbModeUrl.style.color = '';
    thumbModeUrl.style.fontWeight = '';
    thumbUrlMode.style.display = 'none';
    thumbSvgMode.style.display = '';
  }

  thumbModeUrl.addEventListener('click', activateThumbUrlMode);
  thumbModeSvg.addEventListener('click', activateThumbSvgMode);

  /* Convert SVG code to a URL-encoded data URI and apply as thumbnail */
  thumbSvgApply.addEventListener('click', function() {
    const svgCode = thumbSvgCode.value.trim();
    if (!svgCode || !svgCode.toLowerCase().startsWith('<svg')) {
      thumbSvgError.style.display = 'inline';
      return;
    }
    thumbSvgError.style.display = 'none';
    const dataUri = 'data:image/svg+xml;charset=utf-8,' + encodeURIComponent(svgCode);
    thumbInput.value = dataUri;
    updateThumbPreview();
    updateSerp();
  });

  /* ── SVG Insert for Content ── */
  const svgContentTrigger = document.getElementById('svgContentTrigger');
  const svgContentPanel   = document.getElementById('svgContentPanel');
  const svgContentCancel  = document.getElementById('svgContentCancel');
  const svgContentInsert  = document.getElementById('svgContentInsert');
  const svgContentCode    = document.getElementById('svgContentCode');
  const svgContentError   = document.getElementById('svgContentError');

  svgContentTrigger.addEventListener('click', function() {
    svgContentPanel.style.display = 'block';
    svgContentCode.value = '';
    svgContentError.style.display = 'none';
    svgContentCode.focus();
  });

  svgContentCancel.addEventListener('click', function() {
    svgContentPanel.style.display = 'none';
    svgContentCode.value = '';
    svgContentError.style.display = 'none';
  });

  svgContentInsert.addEventListener('click', function() {
    const svgCode = svgContentCode.value.trim();
    if (!svgCode || !svgCode.toLowerCase().startsWith('<svg')) {
      svgContentError.style.display = 'inline';
      return;
    }
    svgContentError.style.display = 'none';
    /* Convert to data URI and insert as image into Quill */
    const dataUri = 'data:image/svg+xml;charset=utf-8,' + encodeURIComponent(svgCode);
    const range = quill.getSelection(true) || { index: quill.getLength() - 1 };
    quill.insertEmbed(range.index, 'image', dataUri);
    quill.setSelection(range.index + 1);
    svgContentPanel.style.display = 'none';
    svgContentCode.value = '';
  });

  /* ── SERP Preview helpers ── */
  const titleEl   = document.getElementById('title');
  const metaTitle = document.getElementById('meta_title');
  const metaDesc  = document.getElementById('meta_description');
  const slugHint  = '<%= isEdit ? article.slug : "" %>';

  function getSlug(str) {
    return str.toLowerCase().trim().replace(/[^\w\s-]/g, '').replace(/[\s_]+/g, '-').replace(/-+/g, '-').replace(/^-+|-+$/g, '') || 'article-slug';
  }

  function updateSerp() {
    const titleVal = metaTitle.value.trim() || titleEl.value.trim() || 'Article Title';
    const descVal  = metaDesc.value.trim() || document.getElementById('summary').value.trim() || 'Meta description will appear here...';
    const slug     = slugHint || getSlug(titleEl.value);

    document.getElementById('serpUrl').textContent   = 'value.codes › blog › ' + slug;
    document.getElementById('serpTitle').textContent = titleVal + (titleVal ? ' — Value.Codes' : '');
    document.getElementById('serpDesc').textContent  = descVal.slice(0, 160) + (descVal.length > 160 ? '…' : '');

    /* Social card */
    document.getElementById('socialTitle').textContent = titleVal;
    document.getElementById('socialDesc').textContent  = descVal.slice(0, 125) + (descVal.length > 125 ? '…' : '');

    const thumb = thumbInput.value.trim();
    const socialImg = document.getElementById('socialImage');
    if (thumb) {
      socialImg.innerHTML = '<img src="' + thumb + '" alt="thumbnail" style="width:100%;height:100%;object-fit:cover;" onerror="this.parentNode.innerHTML=\'<span>Image not found</span>\'">';
    } else {
      socialImg.innerHTML = '<span>No thumbnail set</span>';
    }
  }

  [titleEl, metaTitle, metaDesc, document.getElementById('summary'), thumbInput].forEach(function(el) {
    if (el) el.addEventListener('input', updateSerp);
  });
  updateSerp();

  /* ── Character counters ── */
  function updateCounter(input, counterId, barId, max, greenMin, greenMax) {
    const len = input.value.length;
    const counter = document.getElementById(counterId);
    const bar = document.getElementById(barId);

    counter.textContent = len + '/' + max;

    let status;
    if (len >= greenMin && len <= greenMax) {
      status = 'good';
    } else if (len > 0) {
      status = (len < greenMin - 15 || len > greenMax + 20) ? 'bad' : 'warn';
    } else {
      status = '';
    }
    counter.className = 'admin-char-counter' + (status ? ' admin-char-counter--' + status : '');

    const pct = Math.min(100, Math.round((len / max) * 100));
    bar.style.width = pct + '%';
    bar.className = 'admin-char-bar__fill' + (status ? ' admin-char-bar__fill--' + status : '');
  }

  metaTitle.addEventListener('input', function() {
    updateCounter(this, 'metaTitleCounter', 'metaTitleBar', 60, 50, 60);
    updateSerp();
  });
  metaDesc.addEventListener('input', function() {
    updateCounter(this, 'metaDescCounter', 'metaDescBar', 160, 120, 160);
    updateSerp();
  });

  /* Init counters with existing values */
  updateCounter(metaTitle, 'metaTitleCounter', 'metaTitleBar', 60, 50, 60);
  updateCounter(metaDesc, 'metaDescCounter', 'metaDescBar', 160, 120, 160);

  /* ── Social Preview Toggle ── */
  document.getElementById('socialToggle').addEventListener('click', function() {
    const panel = document.getElementById('socialPanel');
    const expanded = this.getAttribute('aria-expanded') === 'true';
    this.setAttribute('aria-expanded', String(!expanded));
    panel.hidden = expanded;
    updateSerp();
  });

})();
</script>
