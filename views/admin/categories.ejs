<%# Admin Categories Management %>
<div class="admin-page">
  <div class="admin-page-header">
    <div>
      <h1 class="admin-page-title">Categories</h1>
      <p class="admin-page-subtitle">Organize your blog articles</p>
    </div>
  </div>

  <% if (typeof flash !== 'undefined' && flash) { %>
  <div class="admin-alert admin-alert--<%= flash.type %>" role="alert"><%= flash.message %></div>
  <% } %>

  <div class="admin-categories-layout">
    <div class="admin-sidebar-card">
      <h2 class="admin-sidebar-card__title">Add New Category</h2>
      <form action="/admin/categories/new" method="POST" class="admin-cat-form">
        <div class="admin-form-group">
          <label for="cat-name" class="admin-form-label admin-form-label--required">Name</label>
          <input
            type="text"
            id="cat-name"
            name="name"
            class="admin-form-input"
            placeholder="e.g. Web Development"
            maxlength="100"
            required
          >
        </div>
        <div class="admin-form-group">
          <label for="cat-desc" class="admin-form-label">Description</label>
          <input
            type="text"
            id="cat-desc"
            name="description"
            class="admin-form-input"
            placeholder="Short description (optional)"
            maxlength="500"
          >
        </div>
        <p class="admin-form-hint admin-form-hint--block">Slug is auto-generated from the name.</p>
        <button type="submit" class="admin-btn admin-btn--primary">Add Category</button>
      </form>
    </div>

    <div class="admin-table-wrap">
      <% if (categories.length === 0) { %>
        <div class="admin-empty">
          <h3>No categories yet</h3>
          <p>Add your first category using the form.</p>
        </div>
      <% } else { %>
      <table class="admin-table" aria-label="Categories list">
        <thead>
          <tr>
            <th>Name</th>
            <th>Slug</th>
            <th>Articles</th>
            <th>Actions</th>
          </tr>
        </thead>
        <tbody>
          <% categories.forEach(function(cat) { %>
          <tr>
            <td class="admin-table__title-cell">
              <strong><%= cat.name %></strong>
              <% if (cat.description) { %>
                <span class="admin-table__slug"><%= cat.description %></span>
              <% } %>
            </td>
            <td><code class="admin-code">/blog/category/<%= cat.slug %></code></td>
            <td>
              <span class="admin-badge admin-badge--category"><%= cat.article_count %></span>
            </td>
            <td class="admin-table__actions">
              <button
                type="button"
                class="admin-action-btn"
                title="Edit category"
                onclick="toggleEditRow('<%= cat.id %>')"
                aria-label="Edit category"
                data-label="Edit"
              ></button>
              <form
                action="/admin/categories/delete/<%= cat.id %>"
                method="POST"
                class="admin-delete-form"
                onsubmit="return confirm('Delete category \'<%= cat.name.replace(/'/g, '') %>\'? Articles will become uncategorised.')"
              >
                <button type="submit" class="admin-action-btn admin-action-btn--danger" title="Delete category" aria-label="Delete category" data-label="Delete"></button>
              </form>
            </td>
          </tr>
          <tr class="admin-edit-row" id="edit-row-<%= cat.id %>" style="display:none">
            <td colspan="4">
              <form action="/admin/categories/edit/<%= cat.id %>" method="POST" class="admin-cat-inline-form">
                <input type="text" name="name" class="admin-form-input" value="<%= cat.name %>" required maxlength="100" placeholder="Category name">
                <input type="text" name="description" class="admin-form-input" value="<%= cat.description || '' %>" maxlength="500" placeholder="Description">
                <button type="submit" class="admin-btn admin-btn--primary admin-btn--sm">Save</button>
                <button type="button" class="admin-btn admin-btn--ghost admin-btn--sm" onclick="toggleEditRow('<%= cat.id %>')">Cancel</button>
              </form>
            </td>
          </tr>
          <% }); %>
        </tbody>
      </table>
      <% } %>
    </div>
  </div>
</div>

<script>
function toggleEditRow(id) {
  const row = document.getElementById('edit-row-' + id);
  if (row) row.style.display = row.style.display === 'none' ? 'table-row' : 'none';
}
</script>
