<%# Admin Articles Dashboard %>
<div class="admin-page">
  <div class="admin-page-header">
    <div>
      <h1 class="admin-page-title">Articles</h1>
      <p class="admin-page-subtitle">Manage your blog posts</p>
    </div>
    <a href="/admin/articles/new" class="admin-btn admin-btn--primary" data-hide-icons="true">
      New Article
    </a>
  </div>

  <% if (typeof flash !== 'undefined' && flash) { %>
  <div class="admin-alert admin-alert--<%= flash.type %>" role="alert">
    <%= flash.message %>
  </div>
  <% } %>

  <div class="admin-stats">
    <div class="admin-stat-card">
      <span class="admin-stat-value"><%= stats.total %></span>
      <span class="admin-stat-label">Total Articles</span>
    </div>
    <div class="admin-stat-card admin-stat-card--green">
      <span class="admin-stat-value"><%= stats.published %></span>
      <span class="admin-stat-label">Published</span>
    </div>
    <div class="admin-stat-card admin-stat-card--orange">
      <span class="admin-stat-value"><%= stats.draft %></span>
      <span class="admin-stat-label">Drafts</span>
    </div>
  </div>

  <div class="admin-filter-bar">
    <form action="/admin/articles" method="GET" class="admin-search-form">
      <div class="admin-search-wrap">
        <input
          type="search"
          name="search"
          class="admin-search-input"
          placeholder="Search by title..."
          value="<%= search %>"
          aria-label="Search articles"
        >
      </div>
      <select name="status" class="admin-select" aria-label="Filter by status">
        <option value="all" <%= statusFilter === 'all' ? 'selected' : '' %>>All Status</option>
        <option value="published" <%= statusFilter === 'published' ? 'selected' : '' %>>Published</option>
        <option value="draft" <%= statusFilter === 'draft' ? 'selected' : '' %>>Draft</option>
      </select>
      <button type="submit" class="admin-btn admin-btn--secondary">Filter</button>
      <% if (search || statusFilter !== 'all') { %>
        <a href="/admin/articles" class="admin-btn admin-btn--ghost">Clear</a>
      <% } %>
    </form>
  </div>

  <div class="admin-table-wrap">
    <% if (articles.length === 0) { %>
      <div class="admin-empty">
        <h3>No articles found</h3>
        <p>
          <% if (search || statusFilter !== 'all') { %>
            Try clearing your filters.
          <% } else { %>
            <a href="/admin/articles/new">Create your first article.</a>
          <% } %>
        </p>
      </div>
    <% } else { %>
    <table class="admin-table" aria-label="Articles list">
      <thead>
        <tr>
          <th>Title</th>
          <th>Category</th>
          <th>Status</th>
          <th>Views</th>
          <th>Date</th>
          <th>Actions</th>
        </tr>
      </thead>
      <tbody>
        <% articles.forEach(function(article) { %>
        <tr>
          <td class="admin-table__title-cell">
            <a href="/admin/articles/edit/<%= article.id %>" class="admin-table__title">
              <%= article.title %>
            </a>
            <span class="admin-table__slug">/blog/<%= article.slug %></span>
          </td>
          <td>
            <span class="admin-badge admin-badge--category">
              <%= article.category_name || 'Unassigned' %>
            </span>
          </td>
          <td>
            <span class="admin-badge admin-badge--<%= article.status %>">
              <%= article.status %>
            </span>
          </td>
          <td class="admin-table__views"><%= (article.views || 0).toLocaleString() %></td>
          <td class="admin-table__date">
            <%= article.published_at
                ? new Date(article.published_at).toLocaleDateString('en-US', { year: 'numeric', month: 'short', day: 'numeric' })
                : new Date(article.created_at).toLocaleDateString('en-US', { year: 'numeric', month: 'short', day: 'numeric' }) %>
          </td>
          <td class="admin-table__actions">
            <a href="/blog/<%= article.slug %>/" target="_blank" class="admin-action-btn" title="View live" aria-label="View article" data-label="View"></a>
            <a href="/admin/articles/edit/<%= article.id %>" class="admin-action-btn" title="Edit article" aria-label="Edit article" data-label="Edit"></a>
            <form action="/admin/articles/delete/<%= article.id %>" method="POST" class="admin-delete-form" onsubmit="return confirm('Delete \'<%= article.title.replace(/'/g, '') %>\'? This cannot be undone.')">
              <button type="submit" class="admin-action-btn admin-action-btn--danger" title="Delete article" aria-label="Delete article" data-label="Delete"></button>
            </form>
          </td>
        </tr>
        <% }); %>
      </tbody>
    </table>
    <% } %>
  </div>
</div>
