<%# ================================================================
    views/compiler.ejs
    Value.Codes — Online Compiler Page (Final Production Build)

    Sections:
    [01] Hero — breadcrumb, badge, h1, desc, stat pills
    [02] AdSense — leaderboard
    [03] Compiler Workspace — toolbar, CodeMirror editor + output
    [04] AdSense — in-article
    [05] Supported Languages Grid
    [06] Features
    [07] FAQ (SEO + FAQ schema via route)
    [08] Related Tools

    Zero inline CSS. Zero inline JS (except AdSense push).
    CodeMirror 5 loaded via CDN (pageCSS/pageJS in route) for syntax highlighting.
    ================================================================ %>

<%# ================================================================
    [01] HERO
    ================================================================ %>
<section class="comp-hero" aria-label="Online Compiler">
  <div class="container">
    <nav class="comp-breadcrumb" aria-label="Breadcrumb">
      <ol>
        <li><a href="/">Home</a></li>
        <li aria-current="page">Online Compiler</li>
      </ol>
    </nav>

    <div class="comp-hero-content">
      <p class="comp-hero-label">Free | No Signup Required</p>

      <h1>Online Compiler &amp; Code Runner</h1>

      <p class="comp-hero-desc">
        Write, compile, and run code in <strong>19 programming languages</strong> directly in your browser.
        Powered by sandboxed execution. Your code runs securely with no setup required.
      </p>

      <div class="comp-stat-pills">
        <span class="comp-stat">19 Languages</span>
        <span class="comp-stat-sep" aria-hidden="true">|</span>
        <span class="comp-stat">STDIN Support</span>
        <span class="comp-stat-sep" aria-hidden="true">|</span>
        <span class="comp-stat">Syntax Highlighting</span>
        <span class="comp-stat-sep" aria-hidden="true">|</span>
        <span class="comp-stat">Ctrl+Enter to Run</span>
        <span class="comp-stat-sep" aria-hidden="true">|</span>
        <span class="comp-stat">Auto-Save</span>
      </div>
    </div>
  </div>
</section>


<%# ================================================================
    [03] COMPILER WORKSPACE
    ================================================================ %>
<section class="compiler" aria-label="Online Compiler workspace">
  <div class="compiler__inner">

    <%# ========== Toolbar ========== %>
    <div class="compiler__toolbar">
      <div class="compiler__toolbar-left">
        <div class="comp-title-row">
          <svg class="comp-title-icon" width="18" height="18" viewBox="0 0 24 24"
               fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true">
            <polyline points="16 18 22 12 16 6"></polyline>
            <polyline points="8 6 2 12 8 18"></polyline>
          </svg>
          <span class="comp-title-text">Code Editor</span>
        </div>
      </div>

      <div class="compiler__toolbar-right">
        <%# --- Theme Toggle --- %>
        <button type="button" class="compiler__icon-btn" id="theme-toggle"
                aria-label="Toggle dark/light theme" title="Toggle Theme">
          <svg class="theme-icon-sun" width="15" height="15" viewBox="0 0 24 24"
               fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true">
            <circle cx="12" cy="12" r="5"></circle>
            <line x1="12" y1="1" x2="12" y2="3"></line>
            <line x1="12" y1="21" x2="12" y2="23"></line>
            <line x1="4.22" y1="4.22" x2="5.64" y2="5.64"></line>
            <line x1="18.36" y1="18.36" x2="19.78" y2="19.78"></line>
            <line x1="1" y1="12" x2="3" y2="12"></line>
            <line x1="21" y1="12" x2="23" y2="12"></line>
            <line x1="4.22" y1="19.78" x2="5.64" y2="18.36"></line>
            <line x1="18.36" y1="5.64" x2="19.78" y2="4.22"></line>
          </svg>
          <svg class="theme-icon-moon" width="15" height="15" viewBox="0 0 24 24"
               fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true">
            <path d="M21 12.79A9 9 0 1 1 11.21 3 7 7 0 0 0 21 12.79z"></path>
          </svg>
        </button>

        <%# --- Language Selector --- %>
        <div class="compiler__lang-group">
          <label for="lang-select" class="sr-only">Select Language</label>
          <select id="lang-select" class="compiler__lang-select"
                  aria-label="Select programming language">
            <option value="python"     data-version="3.10.0" selected>Python</option>
            <option value="javascript" data-version="18.15.0">JavaScript</option>
            <option value="typescript" data-version="5.0.3">TypeScript</option>
            <option value="c++"        data-version="10.2.0">C++</option>
            <option value="c"          data-version="10.2.0">C</option>
            <option value="java"       data-version="15.0.2">Java</option>
            <option value="csharp"     data-version="6.12.0">C#</option>
            <option value="go"         data-version="1.16.2">Go</option>
            <option value="rust"       data-version="1.68.2">Rust</option>
            <option value="ruby"       data-version="3.0.1">Ruby</option>
            <option value="php"        data-version="8.2.3">PHP</option>
            <option value="swift"      data-version="5.3.3">Swift</option>
            <option value="kotlin"     data-version="1.8.20">Kotlin</option>
            <option value="scala"      data-version="3.2.2">Scala</option>
            <option value="r"          data-version="4.1.1">R</option>
            <option value="perl"       data-version="5.36.0">Perl</option>
            <option value="lua"        data-version="5.4.4">Lua</option>
            <option value="bash"       data-version="5.2.0">Bash</option>
            <option value="sql"        data-version="3.36.0">SQL</option>
