<section class="community-page" aria-label="Developer community">
  <div class="community-layout">
    <aside class="community-sidebar" id="communitySidebar" role="navigation" aria-label="Community channels">
      <div class="sidebar-header">
        <h2 class="sidebar-title">Community</h2>
        <button class="sidebar-close-btn" id="sidebarCloseBtn" type="button" aria-label="Close channel list" data-label="Close"></button>
      </div>

      <div class="sidebar-online" aria-live="polite">
        <span class="online-dot" aria-hidden="true"></span>
        <span class="online-text" id="onlineCount">0 online</span>
      </div>

      <div class="channel-group">
        <h3 class="channel-group-title">Open Channels</h3>
        <ul class="channel-list" role="listbox" aria-label="Open channels">
          <% channels.forEach(function(channel, index) { %>
            <li
              class="channel-item<%= index === 0 ? ' is-active' : '' %>"
              role="option"
              aria-selected="<%= index === 0 ? 'true' : 'false' %>"
              data-channel="<%= channel.id %>"
              tabindex="0"
            >
              <span class="channel-name"><%= channel.name %></span>
              <span class="channel-unread" id="unread-<%= channel.id %>" aria-label="Unread messages" style="display:none;">0</span>
            </li>
          <% }); %>
        </ul>
      </div>

      <div class="channel-group">
        <h3 class="channel-group-title">
          Pro Channels
          <span class="badge badge-pro">Pro</span>
        </h3>
        <ul class="channel-list" role="listbox" aria-label="Pro channels">
          <% proChannels.forEach(function(channel) { %>
            <li
              class="channel-item channel-item-pro"
              role="option"
              aria-selected="false"
              data-channel="<%= channel.id %>"
              data-pro="true"
              tabindex="0"
            >
              <span class="channel-name"><%= channel.name %></span>
              <% if (!isLoggedIn || !currentUser.isPro) { %>
                <span class="channel-access">Locked</span>
              <% } else { %>
                <span class="channel-access channel-access--pro">Pro</span>
              <% } %>
            </li>
          <% }); %>
        </ul>
      </div>

      <div class="sidebar-user">
        <% if (isLoggedIn) { %>
          <div class="sidebar-user-info">
            <span class="sidebar-user-avatar" aria-hidden="true"><%= currentUser.username ? currentUser.username.charAt(0).toUpperCase() : '?' %></span>
            <div class="sidebar-user-meta">
              <span class="sidebar-user-name"><%= currentUser.username %></span>
              <span class="sidebar-user-status"><%= currentUser.isPro ? 'Pro member' : 'Community member' %></span>
            </div>
          </div>
        <% } else { %>
          <div class="sidebar-guest-card">
            <p class="sidebar-guest-copy">Sign in to join the conversation, save your place, and unlock private channels.</p>
            <a href="/login" class="btn btn-secondary sidebar-login-btn">Sign In</a>
          </div>
        <% } %>
      </div>
    </aside>

    <div class="community-main">
      <div class="channel-header">
        <button class="channel-menu-btn" id="channelMenuBtn" type="button" aria-label="Open channel list" aria-controls="communitySidebar" data-label="Channels"></button>
        <div class="channel-header-info">
          <h1 class="channel-header-name" id="channelHeaderName">General</h1>
          <p class="channel-header-desc" id="channelHeaderDesc">General developer discussion</p>
        </div>
        <button class="channel-members-btn" id="channelMembersBtn" type="button" aria-label="Toggle channel details" aria-controls="communityMembers" data-label="Info"></button>
      </div>

      <div class="messages-container" id="messagesContainer" role="log" aria-label="Chat messages" aria-live="polite">
        <div class="messages-loading" id="messagesLoading">
          <div class="loading-spinner" aria-hidden="true"></div>
          <p class="loading-text">Loading messages...</p>
        </div>

        <div class="messages-empty" id="messagesEmpty" style="display:none;">
          <h2 class="messages-empty-title">No messages yet</h2>
          <p class="messages-empty-desc">Start the first conversation in this channel.</p>
        </div>

        <div class="messages-list" id="messagesList" aria-label="Messages"></div>
      </div>

      <div class="message-input-area" id="messageInputArea">
        <% if (isLoggedIn) { %>
          <form class="message-form" id="messageForm" autocomplete="off">
            <div class="message-input-wrapper">
              <textarea
                class="message-input"
                id="messageInput"
                placeholder="Message #general..."
                rows="1"
                maxlength="2000"
                aria-label="Type your message"
              ></textarea>
              <div class="message-input-actions">
                <span class="message-char-count" id="messageCharCount" aria-live="polite">0/2000</span>
                <button class="btn btn-primary btn-sm message-send-btn" id="messageSendBtn" type="submit" disabled>
                  Send
                </button>
              </div>
            </div>
          </form>
        <% } else { %>
          <div class="message-login-prompt">
            <p class="message-login-text">Read along freely, then sign in when you are ready to post, ask questions, or share your work.</p>
            <a href="/login" class="btn btn-primary btn-sm">Sign In to Participate</a>
          </div>
        <% } %>
      </div>
    </div>

    <aside class="community-members" id="communityMembers" role="complementary" aria-label="Channel details">
      <div class="members-header">
        <h3 class="members-title">Channel Info</h3>
        <button class="members-close-btn" id="membersCloseBtn" type="button" aria-label="Close channel details" data-label="Close"></button>
      </div>

      <div class="members-section">
        <h3 class="members-section-title">About</h3>
        <p class="members-channel-desc" id="membersChannelDesc">General developer discussion</p>
      </div>

      <div class="members-section">
        <h3 class="members-section-title">Rules</h3>
        <ul class="members-rules">
          <li>Keep feedback respectful and specific.</li>
          <li>Post questions in the most relevant channel.</li>
          <li>Avoid spam, scraping, or promotional drops.</li>
          <li>Share reproducible details when reporting bugs.</li>
          <li>Help others when you can.</li>
        </ul>
      </div>

      <div class="members-section">
        <h3 class="members-section-title">Join Our Discord</h3>
        <div class="discord-join">
          <p class="discord-join-text">For live chat, events, and quick replies, continue the conversation on Discord.</p>
          <a class="discord-btn" href="https://discord.gg/qqbCQYG6" target="_blank" rel="noopener noreferrer">
            Join Discord Server
          </a>
        </div>
      </div>

      <div class="members-section">
        <h3 class="members-section-title">Quick Links</h3>
        <ul class="members-links">
          <li><a href="/tools/">Developer Tools</a></li>
          <li><a href="/compiler/">Online Compiler</a></li>
          <li><a href="/resources/">Resources</a></li>
          <li><a href="/blog/">Blog</a></li>
        </ul>
      </div>

      <div class="members-section">
        <div class="ad-slot">Community sponsor space</div>
      </div>
    </aside>
  </div>
</section>

<script type="application/json" id="communityData">
{
  "isLoggedIn": <%= isLoggedIn ? 'true' : 'false' %>,
  "currentUser": <%= isLoggedIn ? JSON.stringify({ id: currentUser.id, username: currentUser.username, is_pro: currentUser.isPro }) : 'null' %>,
  "channels": <%- JSON.stringify(channels) %>,
  "proChannels": <%- JSON.stringify(proChannels) %>
}
</script>
