<!-- ================================================================
     FILE: views/apis/category.ejs
     PURPOSE: Category page â€” /apis/:category
     ================================================================ -->

<div aria-label="<%= category.name %> APIs">

  <section class="api-hero" aria-label="Category introduction">
    <div class="container">
      <nav class="breadcrumb" aria-label="Breadcrumb">
        <a href="/apis/">APIs</a>
        <span aria-hidden="true">â€º</span>
        <span><%= category.name %></span>
      </nav>
      <h1><span aria-hidden="true"><%= category.emoji %></span> <%= category.name %> APIs</h1>
      <p class="section-desc"><%= category.description %> Browse <%= apis.length %> free APIs.</p>
    </div>
  </section>

  <section class="api-all-section" aria-label="<%= category.name %> APIs">
    <div class="container">
      <% if (apis.length === 0) { %>
        <div class="api-no-results">
          <p>No APIs in this category yet. Check back soon!</p>
        </div>
      <% } else { %>
        <div class="api-card-grid">
          <% apis.forEach(function(api) { %>
            <%- include('../partials/api-card', { api: api }) %>
          <% }); %>
        </div>
      <% } %>
    </div>
  </section>

  <section class="api-internal-links" aria-label="Explore more">
    <div class="container">
      <h2>Explore More</h2>
      <ul>
        <li><a href="/apis/">All API Categories</a></li>
        <li><a href="/snippets/">Code Snippets</a></li>
        <li><a href="/tools/">Free Developer Tools</a></li>
      </ul>
    </div>
  </section>

</div>