            <a href="<https://www.solidjs.com/docs/latest>" target="_blank" rel="noopener noreferrer" class="resource-link resource-link--primary">Solid Documentation</a>
            <a href="<https://www.solidjs.com/tutorial/>" target="_blank" rel="noopener noreferrer" class="resource-link">Tutorial</a>
