<!-- views/resources/index.ejs — Developer Documentation Directory page -->
<% layout('layouts/main') %>

<main id="main-content" class="resources-page">

  <!-- ========== HERO SECTION ========== -->
  <section class="resources-hero" aria-label="Documentation directory hero">
    <div class="container">
      <div class="resources-hero__content">
        <span class="section-number">Resources</span>
        <h1 class="resources-hero__title">Developer Documentation Directory</h1>
        <p class="resources-hero__desc">
          A comprehensive, curated directory of official documentation for every major programming language, framework,
          database, and development tool. Direct links to authoritative sources, organized for efficient discovery.
        </p>
        <p class="resources-hero__sub">
          No tutorials. No opinions. Just the official documentation you need to build software properly.
        </p>
        <div class="resources-hero__search">
          <label for="resources-search" class="sr-only">Search documentation resources</label>
          <div class="resources-search-wrap">
            <svg class="resources-search-icon" aria-hidden="true" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="11" cy="11" r="8"/><line x1="21" y1="21" x2="16.65" y2="16.65"/></svg>
            <input type="text" id="resources-search" class="resources-search-input" placeholder="Search documentation resources..." autocomplete="off">
          </div>
        </div>
        <p class="resources-hero__note">
          Use the search above to quickly filter documentation resources, or browse by category below.
          All links point directly to official, maintained documentation sources.
        </p>
      </div>
    </div>
  </section>

  <!-- ========== JUMP TO CATEGORY ========== -->
  <nav class="resources-jumpnav" aria-label="Jump to documentation category">
    <div class="container">
      <h2 class="resources-jumpnav__title">Jump to Category</h2>
      <ul class="resources-jumpnav__list">
        <li><a href="#languages" class="resources-jumpnav__link">Languages</a></li>
        <li><a href="#frontend" class="resources-jumpnav__link">Frontend</a></li>
        <li><a href="#backend" class="resources-jumpnav__link">Backend</a></li>
        <li><a href="#databases" class="resources-jumpnav__link">Databases</a></li>
        <li><a href="#devops" class="resources-jumpnav__link">DevOps</a></li>
        <li><a href="#mobile" class="resources-jumpnav__link">Mobile</a></li>
        <li><a href="#apis" class="resources-jumpnav__link">APIs &amp; Protocols</a></li>
        <li><a href="#vcs" class="resources-jumpnav__link">Version Control</a></li>
      </ul>
    </div>
  </nav>

  <!-- ADSENSE: leaderboard -->

  <!-- ========== 01 — PROGRAMMING LANGUAGES ========== -->
  <section id="languages" class="resources-category section-padding" aria-label="Programming languages documentation">
    <div class="container">
      <div class="resources-category__header">
        <span class="section-number">01</span>
        <h2 class="resources-category__title">Programming Languages</h2>
        <p class="resources-category__desc">
          Official documentation for major programming languages. These resources provide comprehensive language specifications,
          standard library references, and authoritative guides to syntax and semantics. Understanding language documentation is
          fundamental to writing idiomatic, efficient code that leverages the full power of each platform.
        </p>
        <p class="resources-category__subdesc">
          Each language's official documentation typically includes getting started guides for newcomers, comprehensive API
          references for the standard library, language specification details for advanced users, and release notes tracking
          changes across versions. Bookmark these as your primary reference when working in any language.
        </p>
      </div>

      <div class="resources-grid">

        <!-- Python -->
        <article class="resource-card" data-search="python beginner programming language standard library">
          <div class="resource-card__header">
            <div class="resource-card__badges">
              <span class="badge badge-pill resource-badge--beginner">Beginner Friendly</span>
            </div>
            <h3 class="resource-card__title">Python</h3>
          </div>
          <p class="resource-card__desc">
            Python's official documentation is exceptionally well-written, featuring tutorials for beginners, comprehensive
            standard library references, and the language reference specification. The documentation includes extensive
            examples and follows clear conventions that make learning Python straightforward.
          </p>
          <div class="resource-card__links">
            <a href="<https://docs.python.org/3/>" target="_blank" rel="noopener noreferrer" class="resource-link resource-link--primary">Official Documentation</a>
            <a href="<https://docs.python.org/3/tutorial/>" target="_blank" rel="noopener noreferrer" class="resource-link">Python Tutorial</a>
            <a href="<https://docs.python.org/3/library/>" target="_blank" rel="noopener noreferrer" class="resource-link">Standard Library</a>
            <a href="<https://peps.python.org/>" target="_blank" rel="noopener noreferrer" class="resource-link">Python Enhancement Proposals</a>
            <a href="<https://www.python.org/community/>" target="_blank" rel="noopener noreferrer" class="resource-link">Community Resources</a>
          </div>
        </article>

        <!-- JavaScript -->
        <article class="resource-card" data-search="javascript js mdn ecmascript web development node nodejs">
          <div class="resource-card__header">
            <div class="resource-card__badges">
              <span class="badge badge-pill resource-badge--popular">Most Popular</span>
            </div>
            <h3 class="resource-card__title">JavaScript</h3>
          </div>
          <p class="resource-card__desc">
            JavaScript documentation through MDN Web Docs is the gold standard for web development references. It covers
            ECMAScript specifications, browser APIs, and includes compatibility tables. Essential for both frontend and
            Node.js backend development.
          </p>
          <div class="resource-card__links">
            <a href="<https://developer.mozilla.org/en-US/docs/Web/JavaScript/Guide>" target="_blank" rel="noopener noreferrer" class="resource-link resource-link--primary">MDN JavaScript Guide</a>
            <a href="<https://tc39.es/ecma262/>" target="_blank" rel="noopener noreferrer" class="resource-link">ECMAScript Specification</a>
            <a href="<https://developer.mozilla.org/en-US/docs/Web/JavaScript/Reference>" target="_blank" rel="noopener noreferrer" class="resource-link">JavaScript Reference</a>
            <a href="<https://nodejs.org/docs/latest/api/>" target="_blank" rel="noopener noreferrer" class="resource-link">Node.js API Docs</a>
            <a href="<https://github.com/tc39/proposals>" target="_blank" rel="noopener noreferrer" class="resource-link">TC39 Proposals</a>
          </div>
        </article>

        <!-- TypeScript -->
        <article class="resource-card" data-search="typescript ts typed javascript static typing">
          <div class="resource-card__header">
            <h3 class="resource-card__title">TypeScript</h3>
          </div>
          <p class="resource-card__desc">
            TypeScript's documentation provides comprehensive coverage of the type system, compiler options, and advanced
            features. Essential reading for anyone building scalable JavaScript applications with static typing. The handbook
            is particularly well-structured for progressive learning.
          </p>
          <div class="resource-card__links">
            <a href="<https://www.typescriptlang.org/docs/>" target="_blank" rel="noopener noreferrer" class="resource-link resource-link--primary">Official Documentation</a>
            <a href="<https://www.typescriptlang.org/docs/handbook/>" target="_blank" rel="noopener noreferrer" class="resource-link">TypeScript Handbook</a>
            <a href="<https://www.typescriptlang.org/tsconfig>" target="_blank" rel="noopener noreferrer" class="resource-link">TSConfig Reference</a>
            <a href="<https://www.typescriptlang.org/play>" target="_blank" rel="noopener noreferrer" class="resource-link">TypeScript Playground</a>
          </div>
        </article>

        <!-- Java -->
        <article class="resource-card" data-search="java oracle jvm jdk se enterprise">
          <div class="resource-card__header">
            <h3 class="resource-card__title">Java</h3>
          </div>
          <p class="resource-card__desc">
            Java documentation includes comprehensive API specifications, tutorials, and the language specification itself.
            Oracle's Java SE documentation is the authoritative source for understanding the platform, from basic syntax to
            advanced concurrency patterns.
          </p>
          <div class="resource-card__links">
            <a href="<https://docs.oracle.com/en/java/>" target="_blank" rel="noopener noreferrer" class="resource-link resource-link--primary">Oracle Java Documentation</a>
            <a href="<https://docs.oracle.com/javase/tutorial/>" target="_blank" rel="noopener noreferrer" class="resource-link">Java Tutorials</a>
            <a href="<https://docs.oracle.com/en/java/javase/21/docs/api/>" target="_blank" rel="noopener noreferrer" class="resource-link">Java SE API</a>
            <a href="<https://openjdk.org/>" target="_blank" rel="noopener noreferrer" class="resource-link">OpenJDK Project</a>
          </div>
        </article>

        <!-- C++ -->
        <article class="resource-card" data-search="c++ cpp cplusplus systems programming memory templates">
          <div class="resource-card__header">
            <h3 class="resource-card__title">C++</h3>
          </div>
          <p class="resource-card__desc">
            C++ documentation spans multiple sources, with cppreference.com being the community standard and the ISO standard
            being the official specification. Essential for understanding memory management, templates, and modern C++ features
            through C++23.
          </p>
          <div class="resource-card__links">
            <a href="<https://en.cppreference.com/>" target="_blank" rel="noopener noreferrer" class="resource-link resource-link--primary">cppreference.com</a>
            <a href="<https://isocpp.org/std/the-standard>" target="_blank" rel="noopener noreferrer" class="resource-link">ISO C++ Standards</a>
            <a href="<https://en.cppreference.com/w/cpp/language>" target="_blank" rel="noopener noreferrer" class="resource-link">Language Reference</a>
            <a href="<https://en.cppreference.com/w/cpp/header>" target="_blank" rel="noopener noreferrer" class="resource-link">Standard Library</a>
          </div>
        </article>

        <!-- Rust -->
        <article class="resource-card" data-search="rust systems programming ownership memory safety cargo">
          <div class="resource-card__header">
            <div class="resource-card__badges">
              <span class="badge badge-pill resource-badge--modern">Modern</span>
            </div>
            <h3 class="resource-card__title">Rust</h3>
          </div>
          <p class="resource-card__desc">
            Rust's documentation is exemplary, featuring "The Book" for learning, comprehensive API docs, and the reference.
            The ownership and borrowing system is explained thoroughly, making Rust's memory safety guarantees accessible to
            developers from all backgrounds.
          </p>
          <div class="resource-card__links">
            <a href="<https://www.rust-lang.org/learn>" target="_blank" rel="noopener noreferrer" class="resource-link resource-link--primary">Official Documentation</a>
            <a href="<https://doc.rust-lang.org/book/>" target="_blank" rel="noopener noreferrer" class="resource-link">The Rust Book</a>
            <a href="<https://doc.rust-lang.org/std/>" target="_blank" rel="noopener noreferrer" class="resource-link">Standard Library</a>
            <a href="<https://doc.rust-lang.org/reference/>" target="_blank" rel="noopener noreferrer" class="resource-link">Rust Reference</a>
            <a href="<https://doc.rust-lang.org/cargo/>" target="_blank" rel="noopener noreferrer" class="resource-link">Cargo Documentation</a>
          </div>
        </article>

        <!-- Go -->
        <article class="resource-card" data-search="go golang cloud native systems programming concurrency">
          <div class="resource-card__header">
            <h3 class="resource-card__title">Go</h3>
          </div>
          <p class="resource-card__desc">
            Go's documentation emphasizes simplicity and clarity, reflecting the language's design philosophy. The standard
            library documentation is extensive, and "Effective Go" provides idiomatic patterns. Essential for cloud-native
            and systems programming.
          </p>
          <div class="resource-card__links">
            <a href="<https://go.dev/doc/>" target="_blank" rel="noopener noreferrer" class="resource-link resource-link--primary">Official Documentation</a>
            <a href="<https://go.dev/tour/>" target="_blank" rel="noopener noreferrer" class="resource-link">A Tour of Go</a>
            <a href="<https://pkg.go.dev/std>" target="_blank" rel="noopener noreferrer" class="resource-link">Standard Library</a>
            <a href="<https://go.dev/doc/effective_go>" target="_blank" rel="noopener noreferrer" class="resource-link">Effective Go</a>
            <a href="<https://go.dev/ref/spec>" target="_blank" rel="noopener noreferrer" class="resource-link">Language Specification</a>
          </div>
        </article>

        <!-- C# -->
        <article class="resource-card" data-search="c# csharp dotnet .net microsoft async linq">
          <div class="resource-card__header">
            <h3 class="resource-card__title">C#</h3>
          </div>
          <p class="resource-card__desc">
            Microsoft's C# documentation covers the language, .NET framework, and platform-specific development. The docs
            include excellent tutorials, API references, and guidance on modern features like async/await and LINQ.
          </p>
          <div class="resource-card__links">
            <a href="<https://learn.microsoft.com/en-us/dotnet/csharp/>" target="_blank" rel="noopener noreferrer" class="resource-link resource-link--primary">C# Documentation</a>
            <a href="<https://learn.microsoft.com/en-us/dotnet/api/>" target="_blank" rel="noopener noreferrer" class="resource-link">.NET API Browser</a>
            <a href="<https://learn.microsoft.com/en-us/dotnet/csharp/tour-of-csharp/>" target="_blank" rel="noopener noreferrer" class="resource-link">C# Tour</a>
            <a href="<https://github.com/dotnet/csharplang/tree/main/proposals>" target="_blank" rel="noopener noreferrer" class="resource-link">Language Proposals</a>
          </div>
        </article>

        <!-- Ruby -->
        <article class="resource-card" data-search="ruby rails metaprogramming elegant expressive">
          <div class="resource-card__header">
            <h3 class="resource-card__title">Ruby</h3>
          </div>
          <p class="resource-card__desc">
            Ruby's documentation includes comprehensive API references and guides to the language's elegant, expressive syntax.
            The Ruby core and standard library docs are essential for understanding the language's powerful metaprogramming
            capabilities.
          </p>
          <div class="resource-card__links">
            <a href="<https://www.ruby-lang.org/en/documentation/>" target="_blank" rel="noopener noreferrer" class="resource-link resource-link--primary">Official Documentation</a>
            <a href="<https://ruby-doc.org/>" target="_blank" rel="noopener noreferrer" class="resource-link">Ruby-Doc.org</a>
            <a href="<https://ruby-doc.org/core/>" target="_blank" rel="noopener noreferrer" class="resource-link">Core API</a>
            <a href="<https://guides.rubyonrails.org/>" target="_blank" rel="noopener noreferrer" class="resource-link">Rails Guides</a>
          </div>
        </article>

        <!-- PHP -->
        <article class="resource-card" data-search="php web development server side scripting">
          <div class="resource-card__header">
            <h3 class="resource-card__title">PHP</h3>
          </div>
          <p class="resource-card__desc">
            PHP's manual is one of the most comprehensive language documentations available, with user-contributed notes that
            provide real-world context. Essential for web development, covering both procedural and object-oriented approaches.
          </p>
          <div class="resource-card__links">
            <a href="<https://www.php.net/manual/en/>" target="_blank" rel="noopener noreferrer" class="resource-link resource-link--primary">PHP Manual</a>
            <a href="<https://www.php.net/docs.php>" target="_blank" rel="noopener noreferrer" class="resource-link">Official Documentation</a>
            <a href="<https://www.php-fig.org/psr/>" target="_blank" rel="noopener noreferrer" class="resource-link">PHP Standards</a>
            <a href="<https://wiki.php.net/rfc>" target="_blank" rel="noopener noreferrer" class="resource-link">PHP RFCs</a>
          </div>
        </article>

        <!-- Swift -->
        <article class="resource-card" data-search="swift apple ios macos protocol oriented programming">
          <div class="resource-card__header">
            <h3 class="resource-card__title">Swift</h3>
          </div>
          <p class="resource-card__desc">
            Apple's Swift documentation covers the language comprehensively, from basic syntax to advanced features like
            protocol-oriented programming. Essential for iOS, macOS, and cross-platform development with Swift.
          </p>
          <div class="resource-card__links">
            <a href="<https://www.swift.org/documentation/>" target="_blank" rel="noopener noreferrer" class="resource-link resource-link--primary">Swift.org Documentation</a>
            <a href="<https://docs.swift.org/swift-book/>" target="_blank" rel="noopener noreferrer" class="resource-link">The Swift Book</a>
            <a href="<https://developer.apple.com/documentation/swift>" target="_blank" rel="noopener noreferrer" class="resource-link">Apple Swift Docs</a>
