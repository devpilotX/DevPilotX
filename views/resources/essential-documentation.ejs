  <!-- ADSENSE: in-article -->

  <!-- ========== 02 — FRONTEND FRAMEWORKS ========== -->
  <section id="frontend" class="resources-category section-padding" aria-label="Frontend frameworks documentation">
    <div class="container">
      <div class="resources-category__header">
        <span class="section-number">02</span>
        <h2 class="resources-category__title">Frontend Frameworks &amp; Libraries</h2>
        <p class="resources-category__desc">
          Modern frontend development relies on frameworks that provide structure, reactivity, and efficient rendering. These
          official documentation resources cover component architecture, state management, routing, and best practices for
          building user interfaces that scale from small applications to enterprise systems.
        </p>
        <p class="resources-category__subdesc">
          Each framework's documentation includes getting started guides, API references, migration guides, and increasingly
          important performance optimization techniques. The ecosystem documentation is equally crucial, covering testing,
          state management libraries, and deployment strategies.
        </p>
      </div>

      <div class="resources-grid">

        <!-- React -->
        <article class="resource-card" data-search="react reactjs hooks components jsx facebook meta frontend ui">
          <div class="resource-card__header">
            <div class="resource-card__badges">
              <span class="badge badge-pill resource-badge--popular">Most Used</span>
            </div>
            <h3 class="resource-card__title">React</h3>
          </div>
          <p class="resource-card__desc">
            React's new documentation focuses on hooks and modern patterns. Comprehensive coverage of component lifecycle,
            state management, and performance optimization. The new docs emphasize learning through interactive examples and
            real-world scenarios.
          </p>
          <div class="resource-card__links">
            <a href="<https://react.dev/>" target="_blank" rel="noopener noreferrer" class="resource-link resource-link--primary">React Documentation</a>
            <a href="<https://react.dev/learn>" target="_blank" rel="noopener noreferrer" class="resource-link">Learn React</a>
            <a href="<https://react.dev/reference/react>" target="_blank" rel="noopener noreferrer" class="resource-link">API Reference</a>
            <a href="<https://reactnative.dev/>" target="_blank" rel="noopener noreferrer" class="resource-link">React Native</a>
            <a href="<https://nextjs.org/docs>" target="_blank" rel="noopener noreferrer" class="resource-link">Next.js Framework</a>
          </div>
        </article>

        <!-- Vue.js -->
        <article class="resource-card" data-search="vue vuejs composition api options api progressive frontend">
          <div class="resource-card__header">
            <h3 class="resource-card__title">Vue.js</h3>
          </div>
          <p class="resource-card__desc">
            Vue's documentation is renowned for clarity and progressive learning approach. Covers the Composition API,
            Options API, and ecosystem tools. Excellent for developers seeking a gentler learning curve than React while
            maintaining enterprise capabilities.
          </p>
          <div class="resource-card__links">
            <a href="<https://vuejs.org/guide/>" target="_blank" rel="noopener noreferrer" class="resource-link resource-link--primary">Vue.js Guide</a>
            <a href="<https://vuejs.org/api/>" target="_blank" rel="noopener noreferrer" class="resource-link">API Reference</a>
            <a href="<https://vuejs.org/examples/>" target="_blank" rel="noopener noreferrer" class="resource-link">Examples</a>
            <a href="<https://router.vuejs.org/>" target="_blank" rel="noopener noreferrer" class="resource-link">Vue Router</a>
            <a href="<https://pinia.vuejs.org/>" target="_blank" rel="noopener noreferrer" class="resource-link">Pinia State Management</a>
          </div>
        </article>

        <!-- Angular -->
        <article class="resource-card" data-search="angular typescript rxjs dependency injection google frontend enterprise">
          <div class="resource-card__header">
            <h3 class="resource-card__title">Angular</h3>
          </div>
          <p class="resource-card__desc">
            Angular's comprehensive documentation covers the complete framework including TypeScript, RxJS, and dependency
            injection. Suited for large-scale applications with strong opinions on architecture and testing. The CLI
            documentation is particularly valuable.
          </p>
          <div class="resource-card__links">
            <a href="<https://angular.dev/>" target="_blank" rel="noopener noreferrer" class="resource-link resource-link--primary">Angular Documentation</a>
            <a href="<https://angular.dev/overview>" target="_blank" rel="noopener noreferrer" class="resource-link">Architecture Guide</a>
            <a href="<https://angular.dev/api>" target="_blank" rel="noopener noreferrer" class="resource-link">API Reference</a>
            <a href="<https://angular.dev/tools/cli>" target="_blank" rel="noopener noreferrer" class="resource-link">Angular CLI</a>
            <a href="<https://material.angular.io/>" target="_blank" rel="noopener noreferrer" class="resource-link">Angular Material</a>
          </div>
        </article>

        <!-- Svelte -->
        <article class="resource-card" data-search="svelte sveltekit compiler reactive frontend no virtual dom">
          <div class="resource-card__header">
            <div class="resource-card__badges">
              <span class="badge badge-pill resource-badge--rising">Rising Star</span>
            </div>
            <h3 class="resource-card__title">Svelte</h3>
          </div>
          <p class="resource-card__desc">
            Svelte's documentation emphasizes simplicity and compiler-driven reactivity. Unlike virtual DOM frameworks, Svelte
