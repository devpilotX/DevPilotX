  <!-- ========== SECTION 2: DESIGN PATTERNS ========== -->
  <section class="bp-section bp-section--alt" id="design-patterns" aria-label="Design Patterns">
    <div class="container">
      <div class="bp-section-header">
        <span class="section-number">[02]</span>
        <h2>Design Patterns</h2>
      </div>
      <p class="bp-section-desc">Proven solutions to recurring software design problems. Know when to use them — and when not to.</p>

      <div class="bp-grid">

        <article class="bp-card">
          <div class="bp-card-top">
            <span class="bp-card-icon" aria-hidden="true">
              <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="2" y="7" width="20" height="14" rx="2" ry="2"></rect><path d="M16 21V5a2 2 0 0 0-2-2h-4a2 2 0 0 0-2 2v16"></path></svg>
            </span>
            <div class="bp-card-tags">
              <span class="tag">Creational</span>
            </div>
          </div>
          <h3 class="bp-card-title">Factory Pattern</h3>
          <p class="bp-card-desc">Create objects without exposing instantiation logic. Use factories when the type of object depends on runtime conditions or configuration.</p>
          <div class="bp-card-example">
            <div class="bp-card-example-header">
              <span class="bp-example-label bp-example-good">✓ Example</span>
            </div>
            <pre><code>function createNotifier(type) {
  switch (type) {
    case 'email': return new EmailNotifier();
    case 'sms':   return new SmsNotifier();
    case 'push':  return new PushNotifier();
    default:
      throw new Error(`Unknown: ${type}`);
  }
}
const notifier = createNotifier('email');</code></pre>
          </div>
          <ul class="bp-card-checklist">
            <li>
              <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><polyline points="20 6 9 17 4 12"></polyline></svg>
              Decouples object creation from usage
            </li>
            <li>
              <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><polyline points="20 6 9 17 4 12"></polyline></svg>
              Easy to add new types without changing consumers
            </li>
            <li>
              <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><polyline points="20 6 9 17 4 12"></polyline></svg>
              Testable — mock the factory in unit tests
            </li>
          </ul>
        </article>

        <article class="bp-card">
          <div class="bp-card-top">
            <span class="bp-card-icon" aria-hidden="true">
              <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"></circle><circle cx="12" cy="12" r="4"></circle><line x1="21.17" y1="8" x2="12" y2="8"></line><line x1="3.95" y1="6.06" x2="8.54" y2="14"></line><line x1="10.88" y1="21.94" x2="15.46" y2="14"></line></svg>
            </span>
            <div class="bp-card-tags">
              <span class="tag">Behavioral</span>
            </div>
          </div>
          <h3 class="bp-card-title">Observer / Event Emitter</h3>
          <p class="bp-card-desc">Decouple components by using publish-subscribe. When something happens, emit an event — interested parties subscribe and react independently.</p>
          <div class="bp-card-example">
            <div class="bp-card-example-header">
              <span class="bp-example-label bp-example-good">✓ Example</span>
            </div>
            <pre><code>const EventEmitter = require('events');
const bus = new EventEmitter();

bus.on('order:placed', (order) => {
  sendConfirmationEmail(order);
});
bus.on('order:placed', (order) => {
  updateInventory(order);
});

bus.emit('order:placed', newOrder);</code></pre>
          </div>
          <ul class="bp-card-checklist">
            <li>
              <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><polyline points="20 6 9 17 4 12"></polyline></svg>
              Loose coupling between publisher and subscribers
            </li>
            <li>
              <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><polyline points="20 6 9 17 4 12"></polyline></svg>
              Add new behaviors without touching existing code
            </li>
            <li>
              <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><polyline points="20 6 9 17 4 12"></polyline></svg>
              Watch for memory leaks — always removeListener
            </li>
          </ul>
        </article>

        <article class="bp-card">
          <div class="bp-card-top">
            <span class="bp-card-icon" aria-hidden="true">
              <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M12 2L2 7l10 5 10-5-10-5z"></path><path d="M2 17l10 5 10-5"></path><path d="M2 12l10 5 10-5"></path></svg>
            </span>
            <div class="bp-card-tags">
              <span class="tag">Structural</span>
            </div>
          </div>
          <h3 class="bp-card-title">Module Pattern &amp; Encapsulation</h3>
          <p class="bp-card-desc">Encapsulate private state and expose only a public API. In JavaScript, use ES modules or IIFEs. Prevents namespace pollution and unintended access.</p>
          <div class="bp-card-example">
            <div class="bp-card-example-header">
              <span class="bp-example-label bp-example-good">✓ Example</span>
            </div>
            <pre><code>// counter.js
let count = 0; // private

export function increment() {
  return ++count;
}
export function getCount() {
  return count;
}
// count is not directly accessible</code></pre>
          </div>
          <ul class="bp-card-checklist">
            <li>
              <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><polyline points="20 6 9 17 4 12"></polyline></svg>
              Hide implementation details
            </li>
            <li>
              <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><polyline points="20 6 9 17 4 12"></polyline></svg>
              Expose minimal public surface area
            </li>
            <li>
              <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><polyline points="20 6 9 17 4 12"></polyline></svg>
              Use ES modules over global scripts
            </li>
          </ul>
        </article>

        <article class="bp-card">
          <div class="bp-card-top">
            <span class="bp-card-icon" aria-hidden="true">
              <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M18 20V10"></path><path d="M12 20V4"></path><path d="M6 20v-6"></path></svg>
            </span>
            <div class="bp-card-tags">
              <span class="tag">Behavioral</span>
            </div>
          </div>
          <h3 class="bp-card-title">Strategy Pattern</h3>
          <p class="bp-card-desc">Define a family of algorithms, encapsulate each one, and make them interchangeable. The strategy pattern lets the algorithm vary independently from clients.</p>
          <div class="bp-card-example">
            <div class="bp-card-example-header">
              <span class="bp-example-label bp-example-good">✓ Example</span>
            </div>
            <pre><code>const strategies = {
  standard: (price) => price,
  premium:  (price) => price * 0.9,
  vip:      (price) => price * 0.8,
};

function getPrice(tier, basePrice) {
  const apply = strategies[tier];
  if (!apply) throw new Error('Unknown tier');
  return apply(basePrice);
}</code></pre>
          </div>
          <ul class="bp-card-checklist">
            <li>
              <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><polyline points="20 6 9 17 4 12"></polyline></svg>
              Eliminates long if/else or switch chains
            </li>
            <li>
              <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><polyline points="20 6 9 17 4 12"></polyline></svg>
              Open/closed principle — extend without modifying
            </li>
            <li>
              <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><polyline points="20 6 9 17 4 12"></polyline></svg>
              Each strategy is independently testable
            </li>
          </ul>
        </article>

        <article class="bp-card">
          <div class="bp-card-top">
            <span class="bp-card-icon" aria-hidden="true">
              <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M4 4h16c1.1 0 2 .9 2 2v12c0 1.1-.9 2-2 2H4c-1.1 0-2-.9-2-2V6c0-1.1.9-2 2-2z"></path><polyline points="22,6 12,13 2,6"></polyline></svg>
            </span>
            <div class="bp-card-tags">
              <span class="tag">Structural</span>
            </div>
          </div>
          <h3 class="bp-card-title">Middleware / Chain of Responsibility</h3>
          <p class="bp-card-desc">Pass a request through a chain of handlers. Each handler processes or passes it along. Express.js middleware is a textbook example of this pattern.</p>
          <div class="bp-card-example">
            <div class="bp-card-example-header">
              <span class="bp-example-label bp-example-good">✓ Example</span>
            </div>
            <pre><code>app.use(helmet());
app.use(compression());
app.use(rateLimit({ max: 100 }));
app.use(authenticate);
app.use(authorize('admin'));
app.get('/dashboard', controller);
// Each layer handles one concern</code></pre>
          </div>
          <ul class="bp-card-checklist">
            <li>
              <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><polyline points="20 6 9 17 4 12"></polyline></svg>
              Each middleware has a single responsibility
            </li>
            <li>
              <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><polyline points="20 6 9 17 4 12"></polyline></svg>
              Order matters — arrange from general to specific
            </li>
            <li>
              <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><polyline points="20 6 9 17 4 12"></polyline></svg>
              Always call next() or send a response
            </li>
          </ul>
        </article>

        <article class="bp-card">
          <div class="bp-card-top">
            <span class="bp-card-icon" aria-hidden="true">
              <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"></circle><line x1="2" y1="12" x2="22" y2="12"></line><path d="M12 2a15.3 15.3 0 0 1 4 10 15.3 15.3 0 0 1-4 10 15.3 15.3 0 0 1-4-10 15.3 15.3 0 0 1 4-10z"></path></svg>
            </span>
            <div class="bp-card-tags">
              <span class="tag">Creational</span>
            </div>
          </div>
          <h3 class="bp-card-title">Singleton (Use Sparingly)</h3>
          <p class="bp-card-desc">Ensure a class has only one instance. Common for database connections, loggers, and config. But overuse creates hidden coupling and testing nightmares.</p>
          <div class="bp-card-example">
            <div class="bp-card-example-header">
              <span class="bp-example-label bp-example-good">✓ Example</span>
            </div>
            <pre><code>// database.js (Node.js module = singleton)
const pool = mysql.createPool({
  host: process.env.DB_HOST,
  user: process.env.DB_USER,
  database: process.env.DB_NAME,
});
module.exports = pool;
// Same pool instance everywhere</code></pre>
          </div>
          <ul class="bp-card-checklist">
            <li>
              <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><polyline points="20 6 9 17 4 12"></polyline></svg>
              Use for shared resources (DB pool, logger)
            </li>
            <li>
              <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><polyline points="20 6 9 17 4 12"></polyline></svg>
              Node.js modules are singletons by default
            </li>
            <li>
              <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><polyline points="20 6 9 17 4 12"></polyline></svg>
              Avoid for business logic — prefer dependency injection
            </li>
          </ul>
        </article>

      </div>
    </div>
  </section>

  <!-- ========== SECTION 3: TESTING STRATEGIES ========== -->
  <section class="bp-section" id="testing-strategies" aria-label="Testing Strategies">
    <div class="container">
      <div class="bp-section-header">
        <span class="section-number">[03]</span>
        <h2>Testing Strategies</h2>
      </div>
      <p class="bp-section-desc">Untested code is broken code you haven't discovered yet. Build a testing culture that catches bugs before users do.</p>

      <div class="bp-grid">

        <article class="bp-card">
          <div class="bp-card-top">
            <span class="bp-card-icon" aria-hidden="true">
              <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M22 11.08V12a10 10 0 1 1-5.93-9.14"></path><polyline points="22 4 12 14.01 9 11.01"></polyline></svg>
            </span>
            <div class="bp-card-tags">
              <span class="tag">Unit Tests</span>
              <span class="tag">Foundation</span>
            </div>
          </div>
          <h3 class="bp-card-title">Write Unit Tests First</h3>
          <p class="bp-card-desc">Unit tests are the foundation of your testing pyramid. Test individual functions and modules in isolation. Aim for fast execution and high coverage of business logic.</p>
          <div class="bp-card-example">
            <div class="bp-card-example-header">
              <span class="bp-example-label bp-example-good">✓ Example</span>
            </div>
            <pre><code>describe('calculateTotal', () => {
  it('applies tax correctly', () => {
    const result = calculateTotal(100);
    expect(result.tax).toBe(18);
    expect(result.total).toBe(118);
  });

  it('handles zero price', () => {
    const result = calculateTotal(0);
    expect(result.total).toBe(0);
  });

  it('throws on negative price', () => {
    expect(() => calculateTotal(-1))
      .toThrow('Price must be positive');
  });
});</code></pre>
          </div>
          <ul class="bp-card-checklist">
            <li>
              <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><polyline points="20 6 9 17 4 12"></polyline></svg>
              Test happy path, edge cases, and error cases
            </li>
            <li>
              <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><polyline points="20 6 9 17 4 12"></polyline></svg>
              Each test should be independent and deterministic
            </li>
            <li>
              <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><polyline points="20 6 9 17 4 12"></polyline></svg>
              Mock external dependencies (DB, API, filesystem)
            </li>
          </ul>
        </article>

        <article class="bp-card">
          <div class="bp-card-top">
            <span class="bp-card-icon" aria-hidden="true">
              <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M12 2L2 7l10 5 10-5-10-5z"></path><path d="M2 17l10 5 10-5"></path><path d="M2 12l10 5 10-5"></path></svg>
            </span>
            <div class="bp-card-tags">
              <span class="tag">Integration</span>
            </div>
          </div>
          <h3 class="bp-card-title">The Testing Pyramid</h3>
          <p class="bp-card-desc">Many unit tests (fast, cheap), fewer integration tests (verify modules work together), and a handful of E2E tests (simulate real user flows). Invert this pyramid and you'll have slow, flaky CI.</p>
          <div class="bp-card-example">
            <div class="bp-card-example-header">
              <span class="bp-example-label bp-example-good">✓ Ratio Guide</span>
            </div>
            <pre><code>Testing Pyramid:

     /  E2E  \\        ~10%  (Cypress, Playwright)
    /----------\\
   / Integration\\      ~20%  (Supertest, DB tests)
  /--------------\\
 /   Unit Tests   \\    ~70%  (Jest, Mocha, Vitest)
/------------------\\</code></pre>
          </div>
          <ul class="bp-card-checklist">
            <li>
              <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><polyline points="20 6 9 17 4 12"></polyline></svg>
              70% unit / 20% integration / 10% E2E
            </li>
            <li>
              <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><polyline points="20 6 9 17 4 12"></polyline></svg>
              Run unit tests on every commit, E2E on merge
            </li>
            <li>
              <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><polyline points="20 6 9 17 4 12"></polyline></svg>
              Track coverage but don't chase 100% blindly
            </li>
          </ul>
        </article>

        <article class="bp-card">
          <div class="bp-card-top">
            <span class="bp-card-icon" aria-hidden="true">
              <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M14.7 6.3a1 1 0 0 0 0 1.4l1.6 1.6a1 1 0 0 0 1.4 0l3.77-3.77a6 6 0 0 1-7.94 7.94l-6.91 6.91a2.12 2.12 0 0 1-3-3l6.91-6.91a6 6 0 0 1 7.94-7.94l-3.76 3.76z"></path></svg>
            </span>
            <div class="bp-card-tags">
              <span class="tag">TDD</span>
            </div>
          </div>
          <h3 class="bp-card-title">Test-Driven Development (TDD)</h3>
          <p class="bp-card-desc">Red → Green → Refactor. Write a failing test first, write the minimum code to pass it, then refactor. TDD produces cleaner APIs and catches regressions immediately.</p>
          <div class="bp-card-example">
            <div class="bp-card-example-header">
              <span class="bp-example-label bp-example-good">✓ TDD Cycle</span>
            </div>
            <pre><code>// 1. RED — Write failing test
it('reverses a string', () => {
  expect(reverse('hello')).toBe('olleh');
}); // ✗ ReferenceError: reverse not defined

// 2. GREEN — Minimum code to pass
function reverse(str) {
  return str.split('').reverse().join('');
} // ✓ Test passes

// 3. REFACTOR — Improve if needed
function reverse(str) {
  return [...str].reverse().join('');
} // ✓ Still passes, cleaner</code></pre>
          </div>
          <ul class="bp-card-checklist">
            <li>
              <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><polyline points="20 6 9 17 4 12"></polyline></svg>
              Forces you to think about API design first
            </li>
            <li>
              <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><polyline points="20 6 9 17 4 12"></polyline></svg>
              Immediate feedback loop catches bugs early
            </li>
            <li>
              <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><polyline points="20 6 9 17 4 12"></polyline></svg>
              100% coverage of tested features by design
            </li>
          </ul>
        </article>

        <article class="bp-card">
          <div class="bp-card-top">
            <span class="bp-card-icon" aria-hidden="true">
              <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="3" y="3" width="18" height="18" rx="2" ry="2"></rect><line x1="3" y1="9" x2="21" y2="9"></line><line x1="9" y1="21" x2="9" y2="9"></line></svg>
            </span>
            <div class="bp-card-tags">
              <span class="tag">CI/CD</span>
            </div>
          </div>
          <h3 class="bp-card-title">Automate Tests in CI</h3>
          <p class="bp-card-desc">Tests that don't run automatically are tests that will be skipped. Wire every test suite into your CI pipeline. Block merges on test failure. No exceptions.</p>
          <div class="bp-card-example">
            <div class="bp-card-example-header">
              <span class="bp-example-label bp-example-good">✓ GitHub Actions</span>
            </div>
            <pre><code>name: CI
on: [push, pull_request]
jobs:
  test:
    runs-on: ubuntu-latest
    steps:
      - uses: actions/checkout@v4
      - uses: actions/setup-node@v4
      - run: npm ci
      - run: npm run lint
      - run: npm test -- --coverage
      - run: npm run test:e2e</code></pre>
          </div>
          <ul class="bp-card-checklist">
            <li>
              <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><polyline points="20 6 9 17 4 12"></polyline></svg>
              Run lint + unit + integration on every push
            </li>
            <li>
              <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><polyline points="20 6 9 17 4 12"></polyline></svg>
              Require passing CI before merge to main
            </li>
            <li>
              <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><polyline points="20 6 9 17 4 12"></polyline></svg>
              Cache node_modules for faster builds
            </li>
          </ul>
        </article>

      </div>
    </div>
  </section>

