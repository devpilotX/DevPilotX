  <section class="content-section" id="roadmaps" aria-label="Detailed career roadmaps">
    <div class="section-header">
      <span class="section-number">[03]</span>
      <h2>Detailed Career Roadmaps</h2>
    </div>
    <p class="section-desc">Six complete roadmaps covering everything you need to know: skills to learn, technologies to master, projects to build, salary expectations, interview preparation, and realistic timelines.</p>

    <!-- ROADMAP NAV TABS -->
    <div class="roadmap-tabs" role="tablist" aria-label="Career path selection">
      <button class="roadmap-tab roadmap-tab-active" role="tab" type="button" aria-selected="true" aria-controls="panel-frontend" id="tab-frontend" data-tab="frontend">
        <span class="roadmap-tab-icon" aria-hidden="true">🎨</span>
        <span class="roadmap-tab-label">Frontend</span>
      </button>
      <button class="roadmap-tab" role="tab" type="button" aria-selected="false" aria-controls="panel-backend" id="tab-backend" data-tab="backend">
        <span class="roadmap-tab-icon" aria-hidden="true">⚙️</span>
        <span class="roadmap-tab-label">Backend</span>
      </button>
      <button class="roadmap-tab" role="tab" type="button" aria-selected="false" aria-controls="panel-fullstack" id="tab-fullstack" data-tab="fullstack">
        <span class="roadmap-tab-icon" aria-hidden="true">🌐</span>
        <span class="roadmap-tab-label">Full Stack</span>
      </button>
      <button class="roadmap-tab" role="tab" type="button" aria-selected="false" aria-controls="panel-devops" id="tab-devops" data-tab="devops">
        <span class="roadmap-tab-icon" aria-hidden="true">🔧</span>
        <span class="roadmap-tab-label">DevOps</span>
      </button>
      <button class="roadmap-tab" role="tab" type="button" aria-selected="false" aria-controls="panel-datascience" id="tab-datascience" data-tab="datascience">
