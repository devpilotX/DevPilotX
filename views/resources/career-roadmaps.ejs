  <!-- SELF-ASSESSMENT -->
  <section class="content-section" id="self-assessment" aria-label="Career path self-assessment">
    <div class="section-header">
      <span class="section-number">[01]</span>
      <h2>How to Choose Your Path</h2>
    </div>
    <p class="section-desc">Different paths suit different people. Your interests, learning style, and career goals all matter. This questionnaire helps you understand which path aligns with your preferences. There's no single <strong>"best" path</strong> — only what works for you.</p>

    <div class="assessment-container">
      <h3 class="assessment-title">Career Path Self-Assessment</h3>
      <p class="assessment-subtitle">Consider these questions honestly. Your answers will point toward paths worth exploring.</p>

      <!-- QUESTION 1 -->
      <div class="assessment-question" data-question="1">
        <h3 class="question-label">1. What type of work energizes you?</h3>
        <div class="question-options">
          <button class="question-option" type="button" data-paths="frontend,mobile" aria-pressed="false">
            <span class="option-icon" aria-hidden="true">🎨</span>
            <div class="option-body">
              <strong>Visual and interactive experiences</strong>
              <span>Creating interfaces users see and interact with daily</span>
            </div>
          </button>
          <button class="question-option" type="button" data-paths="backend,fullstack" aria-pressed="false">
            <span class="option-icon" aria-hidden="true">⚙️</span>
            <div class="option-body">
              <strong>Logic and system architecture</strong>
              <span>Building robust systems that process data and handle business logic</span>
            </div>
          </button>
          <button class="question-option" type="button" data-paths="devops" aria-pressed="false">
            <span class="option-icon" aria-hidden="true">🔧</span>
            <div class="option-body">
              <strong>Infrastructure and automation</strong>
              <span>Optimizing deployments, reliability, and system performance</span>
            </div>
          </button>
          <button class="question-option" type="button" data-paths="datascience" aria-pressed="false">
            <span class="option-icon" aria-hidden="true">📊</span>
            <div class="option-body">
              <strong>Data analysis and predictions</strong>
              <span>Extracting insights from data and building ML models</span>
            </div>
          </button>
        </div>
      </div>

      <!-- QUESTION 2 -->
      <div class="assessment-question" data-question="2">
        <h3 class="question-label">2. How do you prefer to see results?</h3>
        <div class="question-options">
          <button class="question-option" type="button" data-paths="frontend,mobile" aria-pressed="false">
            <span class="option-icon" aria-hidden="true">👁️</span>
            <div class="option-body">
              <strong>Immediate visual feedback</strong>
              <span>See changes instantly in a browser or app → Frontend, Mobile</span>
            </div>
          </button>
          <button class="question-option" type="button" data-paths="backend,devops" aria-pressed="false">
            <span class="option-icon" aria-hidden="true">📈</span>
            <div class="option-body">
              <strong>Performance metrics and logs</strong>
              <span>Success measured through data and system behavior → Backend, DevOps</span>
            </div>
          </button>
          <button class="question-option" type="button" data-paths="datascience" aria-pressed="false">
            <span class="option-icon" aria-hidden="true">🎯</span>
            <div class="option-body">
              <strong>Model accuracy and predictions</strong>
              <span>Validation through statistical measures → Data Science</span>
            </div>
          </button>
          <button class="question-option" type="button" data-paths="fullstack" aria-pressed="false">
            <span class="option-icon" aria-hidden="true">🌐</span>
            <div class="option-body">
              <strong>End-to-end feature completion</strong>
              <span>Build entire features from UI to database → Full Stack</span>
            </div>
          </button>
        </div>
      </div>

      <!-- QUESTION 3 -->
      <div class="assessment-question" data-question="3">
        <h3 class="question-label">3. What aspect of technology interests you most?</h3>
        <div class="question-options">
          <button class="question-option" type="button" data-paths="frontend" aria-pressed="false">
            <span class="option-icon" aria-hidden="true">💅</span>
            <div class="option-body">
              <strong>Design implementation and UX</strong>
              <span>Translating designs into responsive, accessible interfaces → Frontend</span>
            </div>
          </button>
          <button class="question-option" type="button" data-paths="backend" aria-pressed="false">
            <span class="option-icon" aria-hidden="true">🗄️</span>
            <div class="option-body">
              <strong>Databases and APIs</strong>
              <span>Data modeling, queries, server logic → Backend</span>
            </div>
          </button>
          <button class="question-option" type="button" data-paths="devops" aria-pressed="false">
            <span class="option-icon" aria-hidden="true">☁️</span>
            <div class="option-body">
              <strong>Cloud infrastructure and deployment</strong>
              <span>CI/CD pipelines, containers, monitoring → DevOps</span>
            </div>
          </button>
          <button class="question-option" type="button" data-paths="datascience" aria-pressed="false">
            <span class="option-icon" aria-hidden="true">🤖</span>
            <div class="option-body">
              <strong>Machine learning and statistics</strong>
              <span>Algorithms, data analysis, predictive models → Data Science</span>
            </div>
          </button>
          <button class="question-option" type="button" data-paths="mobile" aria-pressed="false">
            <span class="option-icon" aria-hidden="true">📱</span>
            <div class="option-body">
              <strong>Mobile user experiences</strong>
              <span>iOS/Android apps, native features → Mobile</span>
            </div>
          </button>
        </div>
      </div>

      <!-- QUESTION 4 -->
      <div class="assessment-question" data-question="4">
        <h3 class="question-label">4. How much math are you comfortable with?</h3>
        <div class="question-options">
          <button class="question-option" type="button" data-paths="frontend,mobile" aria-pressed="false">
            <span class="option-icon" aria-hidden="true">📐</span>
            <div class="option-body">
              <strong>Basic algebra is fine</strong>
              <span>Frontend, Mobile (minimal math required)</span>
            </div>
          </button>
          <button class="question-option" type="button" data-paths="backend,fullstack,devops" aria-pressed="false">
            <span class="option-icon" aria-hidden="true">🔢</span>
            <div class="option-body">
              <strong>Comfortable with logic and algorithms</strong>
              <span>Backend, Full Stack, DevOps (moderate problem-solving)</span>
            </div>
          </button>
          <button class="question-option" type="button" data-paths="datascience" aria-pressed="false">
            <span class="option-icon" aria-hidden="true">📊</span>
            <div class="option-body">
              <strong>Enjoy statistics, calculus, linear algebra</strong>
              <span>Data Science, ML Engineering (heavy math)</span>
            </div>
          </button>
        </div>
      </div>

      <!-- ASSESSMENT RESULT -->
      <div class="assessment-result" id="assessment-result" aria-live="polite">
        <div class="result-placeholder">
          <p>Answer the questions above to see your recommended career path.</p>
        </div>
        <div class="result-content" id="result-content">
          <h3 class="result-title">Your Recommended Path</h3>
          <div class="result-bars" id="result-bars">
            <!-- Populated by JS -->
          </div>
          <p class="result-note"><strong>Remember:</strong> These are tendencies, not requirements. Many developers successfully work in fields that initially seemed outside their comfort zone. Skills can be learned. What matters most is sustained interest and willingness to practice.</p>
          <a href="#roadmaps" class="btn btn-primary btn-sm">Explore Roadmaps Below</a>
        </div>
      </div>
    </div>
  </section>

