<%# ============================================================ %>
<%# Value.Codes — Global Header                                %>
<%# ============================================================ %>
<header>
  <nav class="site-nav" role="navigation" aria-label="Main navigation">
    <div class="nav-inner">

      <!-- Brand -->
      <div class="nav-brand">
        <a href="/" class="nav-logo" aria-label="Value.Codes Home">
          <span class="nav-logo-text">Value<span class="nav-logo-dot">.</span>Codes</span>
        </a>
        <span class="nav-divider" aria-hidden="true"></span>
        <span class="nav-tagline">Developer Tools</span>
      </div>

      <!-- Right Section -->
      <div class="nav-right">

        <!-- Nav Links -->
        <ul class="nav-links" id="nav-links" role="list">
          <li><a href="/tools/" class="nav-link<%= currentPath && currentPath.startsWith('/tools') ? ' active' : '' %>">Tools</a></li>
          <li><a href="/resources/" class="nav-link<%= currentPath && currentPath.startsWith('/resources') ? ' active' : '' %>">Resources</a></li>
          <li><a href="/blog/" class="nav-link<%= currentPath && currentPath.startsWith('/blog') ? ' active' : '' %>">Blog</a></li>
        </ul>

        <!-- Action Buttons -->
        <div class="nav-actions">

          <a href="/search/" class="nav-search-btn" aria-label="Search" title="Search tools and resources">
            Search
          </a>

          <a href="/compiler/" class="nav-btn-compiler" title="Online Code Compiler" aria-label="Open Compiler">
            Compiler
          </a>

          <% if (!isLoggedIn) { %>
          <a href="/login" class="nav-btn-login" title="Sign in to your account" aria-label="Sign in">
            Sign In
          </a>
          <% } %>

          <% if (isLoggedIn && currentUser) { %>

          <!-- Profile Dropdown -->
          <div id="nav-profile-item" class="nav-profile-item">
            <div class="nav-profile-wrapper">
              <button class="nav-profile-btn" id="nav-profile-toggle" type="button"
                      aria-label="Profile menu" aria-expanded="false" aria-haspopup="true">
                <img class="nav-avatar" id="nav-avatar"
                     src="<%= currentUser.avatar || ('https://ui-avatars.com/api/?name=' + encodeURIComponent(currentUser.username.charAt(0).toUpperCase()) + '&background=c9281a&color=fff&size=52') %>"
                     alt="<%= currentUser.username %> avatar" width="28" height="28" loading="lazy">
                <span id="nav-user-name" class="nav-username"><%= currentUser.username %></span>
                <% if (currentUser.isPro) { %>
                <span class="nav-pro-badge">PRO</span>
                <% } %>
                <span class="nav-chevron" aria-hidden="true">More</span>
              </button>

              <div class="nav-dropdown" id="nav-profile-dropdown" role="menu" aria-hidden="true">
                <div class="dropdown-header">
                  <p class="dropdown-name" id="dropdown-name"><%= currentUser.username %></p>
                  <p class="dropdown-email" id="dropdown-email"><%= currentUser.email %></p>
                </div>
                <% if (currentUser.isPro) { %>
                <div class="dropdown-pro-status">PRO Member</div>
                <% } %>
                <a href="/profile/" class="dropdown-item" role="menuitem">My Profile</a>
                <a href="/settings/" class="dropdown-item" role="menuitem">Settings</a>
                <div class="dropdown-divider" role="separator"></div>
                <a href="/logout" class="dropdown-item dropdown-logout" id="nav-logout-btn" role="menuitem">Log Out</a>
              </div>
            </div>
          </div>

          <% } %>

        </div>
      </div>

      <!-- Mobile Toggle -->
      <button class="menu-toggle" id="menu-toggle" type="button"
              aria-label="Toggle navigation menu" aria-expanded="false" aria-controls="nav-links" data-label="Menu">
        <span class="hamburger-bar"></span>
        <span class="hamburger-bar"></span>
        <span class="hamburger-bar"></span>
      </button>

    </div>
  </nav>
</header>
