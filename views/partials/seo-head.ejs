<%# ============================================================ %>
<%# Value.Codes — SEO Meta Block                               %>
<%# ============================================================ %>
<%# Outputs: title, description, keywords, canonical, OG, etc. %>
<%# All variables passed from route render() calls.            %>
<%# ============================================================ %>

<!-- ========== GOOGLE SEARCH CONSOLE VERIFICATION ========== -->
<% if (typeof googleSiteVerification !== 'undefined' && googleSiteVerification) { %>
<meta name="google-site-verification" content="<%= googleSiteVerification %>">
<% } %>

<!-- ========== PRIMARY META TAGS ========== -->
<title><%= typeof title !== 'undefined' ? title : 'Value.Codes' %></title>
<meta name="description" content="<%= typeof description !== 'undefined' ? description : '' %>">
<% if (typeof keywords !== 'undefined' && keywords) { %>
<meta name="keywords" content="<%= keywords %>">
<% } %>
<meta name="author" content="Value.Codes">
<meta name="robots" content="<%= typeof robots !== 'undefined' ? robots : 'index, follow' %>, max-image-preview:large, max-snippet:-1, max-video-preview:-1">
<% if (typeof canonical !== 'undefined' && canonical) { %>
<link rel="canonical" href="<%= canonical %>">
<% } %>

<!-- ========== OPEN GRAPH / FACEBOOK ========== -->
<meta property="og:type" content="<%= typeof ogType !== 'undefined' ? ogType : 'website' %>">
<% if (typeof canonical !== 'undefined' && canonical) { %>
<meta property="og:url" content="<%= canonical %>">
<% } %>
<meta property="og:title" content="<%= typeof ogTitle !== 'undefined' ? ogTitle : (typeof title !== 'undefined' ? title : 'Value.Codes') %>">
<meta property="og:description" content="<%= typeof ogDescription !== 'undefined' ? ogDescription : (typeof description !== 'undefined' ? description : '') %>">
<% const _ogImage = (typeof ogImage !== 'undefined' && ogImage) ? ogImage : (siteUrl + '/images/og-image.svg'); %>
<meta property="og:image" content="<%= _ogImage %>">
<meta property="og:image:width" content="1200">
<meta property="og:image:height" content="630">
<meta property="og:image:alt" content="Value.Codes — Free Developer Tools Platform">
<meta property="og:site_name" content="Value.Codes">
<meta property="og:locale" content="en_US">

<!-- ========== ARTICLE META (blog posts) ========== -->
<% if (typeof ogType !== 'undefined' && ogType === 'article') { %>
<% if (typeof blog !== 'undefined' && blog) { %>
<meta property="article:published_time" content="<%= blog.published_at || '' %>">
<meta property="article:modified_time" content="<%= blog.updated_at || blog.published_at || '' %>">
<meta property="article:author" content="<%= blog.author || 'Value.Codes' %>">
<meta property="article:section" content="<%= blog.category_name || 'Developer Tools' %>">
<% } %>
<% } %>

<!-- ========== TWITTER CARD ========== -->
<meta name="twitter:card" content="summary_large_image">
<meta name="twitter:site" content="@value_codes">
<meta name="twitter:creator" content="@value_codes">
<% if (typeof canonical !== 'undefined' && canonical) { %>
<meta name="twitter:url" content="<%= canonical %>">
<% } %>
<meta name="twitter:title" content="<%= typeof title !== 'undefined' ? title : 'Value.Codes' %>">
<meta name="twitter:description" content="<%= typeof twitterDescription !== 'undefined' ? twitterDescription : (typeof description !== 'undefined' ? description : '') %>">
<meta name="twitter:image" content="<%= (typeof twitterImage !== 'undefined' && twitterImage) ? twitterImage : _ogImage %>">
<meta name="twitter:image:alt" content="Value.Codes — Free Developer Tools Platform">

<!-- ========== LCP PRELOAD — blog post hero image ========== -->
<% if (typeof preloadImage !== 'undefined' && preloadImage) { %>
<link rel="preload" as="image" href="<%= preloadImage %>" fetchpriority="high">
<% } %>

<!-- ========== APP META — PWA / Mobile ========== -->
<meta name="application-name" content="Value.Codes">
<meta name="apple-mobile-web-app-title" content="Value.Codes">
<meta name="format-detection" content="telephone=no">
<meta name="theme-color" content="#ffffff">
