<!-- ===================================================================
     views/auth/login.ejs — Login Page
     ===================================================================
     Clean, centered login form with email/password fields,
     validation error display, and link to register.
     =================================================================== -->

<section class="auth-page" aria-label="Login">

  <div class="auth-container">

    <!-- ========== AUTH CARD ========== -->
    <div class="auth-card">

      <!-- Logo / Brand -->
      <div class="auth-brand">
        <a href="/" class="auth-logo" aria-label="Value.Codes Home">
          <span class="auth-logo-icon" aria-hidden="true">&lt;/&gt;</span>
          <span class="auth-logo-text">Value<span class="auth-logo-dot">.</span>Codes</span>
        </a>
      </div>

      <!-- Heading -->
      <div class="auth-header">
        <h1 class="auth-title">Welcome back</h1>
        <p class="auth-subtitle">Log in to your account to continue</p>
      </div>

      <!-- Flash Success -->
      <% if (typeof flashSuccess !== 'undefined' && flashSuccess) { %>
        <div class="auth-alert auth-alert-success" role="alert">
          <svg class="auth-alert-icon" width="16" height="16" viewBox="0 0 16 16" fill="none" aria-hidden="true">
            <circle cx="8" cy="8" r="7" stroke="currentColor" stroke-width="1.5"/>
            <path d="M5 8l2 2 4-4" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
          </svg>
          <span><%= flashSuccess %></span>
        </div>
      <% } %>

      <!-- Validation Errors -->
      <% if (errors && errors.length > 0) { %>
        <div class="auth-alert auth-alert-error" role="alert">
          <svg class="auth-alert-icon" width="16" height="16" viewBox="0 0 16 16" fill="none" aria-hidden="true">
            <circle cx="8" cy="8" r="7" stroke="currentColor" stroke-width="1.5"/>
            <path d="M8 5v3M8 10.5v.5" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"/>
          </svg>
          <div class="auth-alert-messages">
            <% errors.forEach(function(error) { %>
              <p><%= error.msg %></p>
            <% }); %>
          </div>
        </div>
      <% } %>

      <!-- Login Form -->
      <form class="auth-form" id="loginForm" method="POST" action="/login" novalidate>

        <!-- Email -->
        <div class="form-group" id="emailGroup">
          <label class="form-label" for="email">Email address</label>
          <div class="form-input-wrapper">
            <svg class="form-input-icon" width="16" height="16" viewBox="0 0 16 16" fill="none" aria-hidden="true">
              <rect x="1.5" y="3" width="13" height="10" rx="2" stroke="currentColor" stroke-width="1.3"/>
              <path d="M1.5 5l6.5 4 6.5-4" stroke="currentColor" stroke-width="1.3" stroke-linecap="round"/>
            </svg>
            <input
              class="form-input"
              type="email"
              id="email"
              name="email"
              placeholder="you@example.com"
              value="<%= oldInput && oldInput.email ? oldInput.email : '' %>"
              autocomplete="email"
              required
              aria-describedby="emailError"
            >
          </div>
          <p class="form-error" id="emailError" role="alert" aria-live="polite"></p>
        </div>

        <!-- Password -->
        <div class="form-group" id="passwordGroup">
          <div class="form-label-row">
            <label class="form-label" for="password">Password</label>
          </div>
          <div class="form-input-wrapper">
            <svg class="form-input-icon" width="16" height="16" viewBox="0 0 16 16" fill="none" aria-hidden="true">
              <rect x="3" y="7" width="10" height="7.5" rx="2" stroke="currentColor" stroke-width="1.3"/>
              <path d="M5 7V5.5a3 3 0 016 0V7" stroke="currentColor" stroke-width="1.3" stroke-linecap="round"/>
              <circle cx="8" cy="11" r="1" fill="currentColor"/>
            </svg>
            <input
              class="form-input"
              type="password"
              id="password"
              name="password"
              placeholder="Enter your password"
              autocomplete="current-password"
              required
              aria-describedby="passwordError"
            >
            <button class="form-toggle-password" type="button" id="togglePassword" aria-label="Show password" tabindex="-1">
              <svg class="eye-icon eye-open" width="18" height="18" viewBox="0 0 18 18" fill="none" aria-hidden="true">
                <path d="M1.5 9s3-5.5 7.5-5.5S16.5 9 16.5 9s-3 5.5-7.5 5.5S1.5 9 1.5 9z" stroke="currentColor" stroke-width="1.3"/>
                <circle cx="9" cy="9" r="2.5" stroke="currentColor" stroke-width="1.3"/>
              </svg>
              <svg class="eye-icon eye-closed" width="18" height="18" viewBox="0 0 18 18" fill="none" aria-hidden="true" style="display:none;">
                <path d="M1.5 9s3-5.5 7.5-5.5S16.5 9 16.5 9s-3 5.5-7.5 5.5S1.5 9 1.5 9z" stroke="currentColor" stroke-width="1.3"/>
                <circle cx="9" cy="9" r="2.5" stroke="currentColor" stroke-width="1.3"/>
                <path d="M3 15L15 3" stroke="currentColor" stroke-width="1.3" stroke-linecap="round"/>
              </svg>
            </button>
          </div>
          <p class="form-error" id="passwordError" role="alert" aria-live="polite"></p>
        </div>

        <!-- Submit -->
        <button class="btn btn-primary btn-lg auth-submit-btn" type="submit" id="loginBtn">
          <span class="btn-text">Log in</span>
          <span class="btn-loader" style="display:none;" aria-hidden="true">
            <span class="btn-spinner"></span>
            Logging in...
          </span>
        </button>

      </form>

      <!-- Divider -->
      <div class="auth-divider">
        <span class="auth-divider-text">or</span>
      </div>

      <!-- Switch to Register -->
      <p class="auth-switch">
        Don't have an account?
        <a href="/register" class="auth-switch-link">Create one free</a>
      </p>

    </div>

    <!-- ========== DECORATIVE FOOTER ========== -->
    <p class="auth-footer-text">
      By logging in you agree to our
      <a href="/legal/terms-of-service">Terms</a> and
      <a href="/legal/privacy-policy">Privacy Policy</a>.
    </p>

  </div>

</section>