<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title><%= typeof title !== 'undefined' ? title : 'Admin — Value.Codes' %></title>
  <meta name="robots" content="noindex, nofollow">
  <link rel="icon" type="image/svg+xml" href="/favicon.svg">
  <link rel="stylesheet" href="/css/global.css">
  <link rel="stylesheet" href="/css/admin.css">
  <% if (typeof pageCSS !== 'undefined' && Array.isArray(pageCSS)) { %>
    <% pageCSS.filter(f => f !== '/css/admin.css').forEach(function(cssFile) { %>
  <link rel="stylesheet" href="<%= cssFile %>">
    <% }); %>
  <% } %>
</head>
<body class="admin-body">

  <!-- ========== MOBILE TOPBAR ========== -->
  <div class="admin-topbar" id="adminTopbar">
    <a href="/" class="admin-topbar-logo">Value<span>.Codes</span></a>
    <button class="admin-topbar-toggle" id="adminSidebarToggle" type="button" aria-label="Toggle sidebar">
      <span></span><span></span><span></span>
    </button>
  </div>

  <!-- ========== SIDEBAR OVERLAY ========== -->
  <div class="admin-sidebar-overlay" id="adminOverlay"></div>

  <!-- ========== ADMIN SIDEBAR ========== -->
  <aside class="admin-sidebar" id="adminSidebar">
    <div class="admin-sidebar__logo">
      <a href="/" class="admin-logo-link">Value<span class="admin-logo-accent">.Codes</span></a>
      <span class="admin-logo-badge">Admin</span>
    </div>

    <nav class="admin-nav" aria-label="Admin navigation">
      <a href="/admin/articles" class="admin-nav__link <%= currentPath && currentPath.startsWith('/admin/articles') ? 'is-active' : '' %>">
        <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z"/><polyline points="14,2 14,8 20,8"/><line x1="16" y1="13" x2="8" y2="13"/><line x1="16" y1="17" x2="8" y2="17"/><polyline points="10,9 9,9 8,9"/></svg>
        Articles
      </a>
      <a href="/admin/articles/new" class="admin-nav__link <%= currentPath === '/admin/articles/new' ? 'is-active' : '' %>">
        <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><line x1="12" y1="5" x2="12" y2="19"/><line x1="5" y1="12" x2="19" y2="12"/></svg>
        New Article
      </a>
      <a href="/admin/categories" class="admin-nav__link <%= currentPath === '/admin/categories' ? 'is-active' : '' %>">
        <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M22 19a2 2 0 0 1-2 2H4a2 2 0 0 1-2-2V5a2 2 0 0 1 2-2h5l2 3h9a2 2 0 0 1 2 2z"/></svg>
        Categories
      </a>
      <div class="admin-nav__divider"></div>
      <a href="/admin/snippets" class="admin-nav__link <%= currentPath && currentPath.startsWith('/admin/snippets') ? 'is-active' : '' %>">
        <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><polyline points="16 18 22 12 16 6"/><polyline points="8 6 2 12 8 18"/></svg>
        Snippets
      </a>
      <a href="/admin/snippets/create" class="admin-nav__link <%= currentPath === '/admin/snippets/create' ? 'is-active' : '' %>">
        <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><line x1="12" y1="5" x2="12" y2="19"/><line x1="5" y1="12" x2="19" y2="12"/></svg>
        New Snippet
      </a>
      <div class="admin-nav__divider"></div>
      <a href="/admin/apis" class="admin-nav__link <%= currentPath && currentPath.startsWith('/admin/apis') ? 'is-active' : '' %>">
        <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><circle cx="12" cy="12" r="10"/><line x1="2" y1="12" x2="22" y2="12"/><path d="M12 2a15.3 15.3 0 0 1 4 10 15.3 15.3 0 0 1-4 10 15.3 15.3 0 0 1-4-10 15.3 15.3 0 0 1 4-10z"/></svg>
        APIs
      </a>
      <a href="/admin/apis/create" class="admin-nav__link <%= currentPath === '/admin/apis/create' ? 'is-active' : '' %>">
        <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><line x1="12" y1="5" x2="12" y2="19"/><line x1="5" y1="12" x2="19" y2="12"/></svg>
        Add API
      </a>
      <div class="admin-nav__divider"></div>
      <a href="/" target="_blank" class="admin-nav__link">
        <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M18 13v6a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2V8a2 2 0 0 1 2-2h6"/><polyline points="15 3 21 3 21 9"/><line x1="10" y1="14" x2="21" y2="3"/></svg>
        View Site
      </a>
      <form action="/admin/logout" method="POST" class="admin-nav__logout-form">
        <button type="submit" class="admin-nav__link admin-nav__link--logout">
          <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M9 21H5a2 2 0 0 1-2-2V5a2 2 0 0 1 2-2h4"/><polyline points="16 17 21 12 16 7"/><line x1="21" y1="12" x2="9" y2="12"/></svg>
          Log Out
        </button>
      </form>
    </nav>
  </aside>

  <!-- ========== ADMIN MAIN ========== -->
  <main class="admin-main" id="adminMain">
    <%- body %>
  </main>

  <script src="/js/global.js" defer></script>
  <% if (typeof pageJS !== 'undefined' && Array.isArray(pageJS)) { %>
    <% pageJS.forEach(function(jsFile) { %>
  <script src="<%= jsFile %>" defer></script>
    <% }); %>
  <% } %>
  <script>
  (function(){
    var toggle = document.getElementById('adminSidebarToggle');
    var sidebar = document.getElementById('adminSidebar');
    var overlay = document.getElementById('adminOverlay');
    if (!toggle || !sidebar || !overlay) return;
    function openSidebar() { sidebar.classList.add('is-open'); overlay.classList.add('is-open'); }
    function closeSidebar() { sidebar.classList.remove('is-open'); overlay.classList.remove('is-open'); }
    toggle.addEventListener('click', function() {
      sidebar.classList.contains('is-open') ? closeSidebar() : openSidebar();
    });
    overlay.addEventListener('click', closeSidebar);
  })();
  </script>
</body>
</html>
