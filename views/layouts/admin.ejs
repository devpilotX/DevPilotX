<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title><%= typeof title !== 'undefined' ? title : 'Admin | Value.Codes' %></title>
  <meta name="robots" content="noindex, nofollow">
  <link rel="icon" type="image/svg+xml" href="/favicon.svg">
  <link rel="stylesheet" href="/css/global.css">
  <link rel="stylesheet" href="/css/admin.css">
  <% if (typeof pageCSS !== 'undefined' && Array.isArray(pageCSS)) { %>
    <% pageCSS.filter(f => f !== '/css/admin.css').forEach(function(cssFile) { %>
  <link rel="stylesheet" href="<%= cssFile %>">
    <% }); %>
  <% } %>
</head>
<body class="admin-body">

  <!-- ========== MOBILE TOPBAR ========== -->
  <div class="admin-topbar" id="adminTopbar">
    <a href="/" class="admin-topbar-logo">Value<span>.Codes</span></a>
    <button class="admin-topbar-toggle" id="adminSidebarToggle" type="button" aria-label="Toggle sidebar" data-label="Menu">
      <span></span><span></span><span></span>
    </button>
  </div>

  <!-- ========== SIDEBAR OVERLAY ========== -->
  <div class="admin-sidebar-overlay" id="adminOverlay"></div>

  <!-- ========== ADMIN SIDEBAR ========== -->
  <aside class="admin-sidebar" id="adminSidebar">
    <div class="admin-sidebar__logo">
      <a href="/" class="admin-logo-link">Value<span class="admin-logo-accent">.Codes</span></a>
      <span class="admin-logo-badge">Admin</span>
    </div>

    <nav class="admin-nav" aria-label="Admin navigation">
      <a href="/admin/articles" class="admin-nav__link <%= currentPath && currentPath.startsWith('/admin/articles') ? 'is-active' : '' %>">
        Articles
      </a>
      <a href="/admin/articles/new" class="admin-nav__link <%= currentPath === '/admin/articles/new' ? 'is-active' : '' %>">
        New Article
      </a>
      <a href="/admin/categories" class="admin-nav__link <%= currentPath === '/admin/categories' ? 'is-active' : '' %>">
        Categories
      </a>
      <div class="admin-nav__divider"></div>
      <a href="/admin/snippets" class="admin-nav__link <%= currentPath && currentPath.startsWith('/admin/snippets') ? 'is-active' : '' %>">
        Snippets
      </a>
      <a href="/admin/snippets/create" class="admin-nav__link <%= currentPath === '/admin/snippets/create' ? 'is-active' : '' %>">
        New Snippet
      </a>
      <div class="admin-nav__divider"></div>
      <a href="/admin/apis" class="admin-nav__link <%= currentPath && currentPath.startsWith('/admin/apis') ? 'is-active' : '' %>">
        APIs
      </a>
      <a href="/admin/apis/create" class="admin-nav__link <%= currentPath === '/admin/apis/create' ? 'is-active' : '' %>">
        Add API
      </a>
      <div class="admin-nav__divider"></div>
      <a href="/" target="_blank" class="admin-nav__link">
        View Site
      </a>
      <form action="/admin/logout" method="POST" class="admin-nav__logout-form">
        <button type="submit" class="admin-nav__link admin-nav__link--logout">
          Log Out
        </button>
      </form>
    </nav>
  </aside>

  <!-- ========== ADMIN MAIN ========== -->
  <main class="admin-main" id="adminMain">
    <%- body %>
  </main>

  <script src="/js/global.js" defer></script>
  <% if (typeof pageJS !== 'undefined' && Array.isArray(pageJS)) { %>
    <% pageJS.forEach(function(jsFile) { %>
  <script src="<%= jsFile %>" defer></script>
    <% }); %>
  <% } %>
  <script>
  (function(){
    var toggle = document.getElementById('adminSidebarToggle');
    var sidebar = document.getElementById('adminSidebar');
    var overlay = document.getElementById('adminOverlay');
    if (!toggle || !sidebar || !overlay) return;
    function openSidebar() { sidebar.classList.add('is-open'); overlay.classList.add('is-open'); }
    function closeSidebar() { sidebar.classList.remove('is-open'); overlay.classList.remove('is-open'); }
    toggle.addEventListener('click', function() {
      sidebar.classList.contains('is-open') ? closeSidebar() : openSidebar();
    });
    overlay.addEventListener('click', closeSidebar);
  })();
  </script>
</body>
</html>
