<%# ============================================================ %>
<%# Value.Codes — Base HTML Layout                               %>
<%# ============================================================ %>
<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0, viewport-fit=cover">

  <%- include('../partials/seo-head') %>

  <!-- ========== FAVICON & TOUCH ICONS ========== -->
  <link rel="icon" type="image/svg+xml" href="/favicon.svg">
  <link rel="apple-touch-icon" href="/apple-touch-icon.png">
  <link rel="manifest" href="/site.webmanifest">

  <!-- ========== RESOURCE HINTS (fastest lookup first) ========== -->
  <link rel="preconnect" href="https://www.googletagmanager.com" crossorigin>
  <link rel="preconnect" href="https://www.google-analytics.com" crossorigin>
  <link rel="preconnect" href="https://pagead2.googlesyndication.com" crossorigin>
  <link rel="preconnect" href="https://googleads.g.doubleclick.net" crossorigin>
  <link rel="preconnect" href="https://api.devpilotx.com" crossorigin>
  <link rel="dns-prefetch" href="https://adservice.google.com">
  <link rel="dns-prefetch" href="https://tpc.googlesyndication.com">
  <link rel="dns-prefetch" href="https://cdn.jsdelivr.net">
  <link rel="dns-prefetch" href="https://ui-avatars.com">

  <!-- ========== PRELOAD CRITICAL ASSETS ========== -->
  <link rel="preload" href="/css/global.css" as="style">
  <link rel="preload" href="/css/header.css" as="style">

  <!-- ========== CRITICAL CSS (above the fold — must block render) ========== -->
  <link rel="stylesheet" href="/css/global.css">
  <link rel="stylesheet" href="/css/header.css">

  <!-- ========== PAGE-SPECIFIC CSS ========== -->
  <% if (typeof pageCSS !== 'undefined' && Array.isArray(pageCSS)) { %>
    <% pageCSS.forEach(function(cssFile) { %>
  <link rel="stylesheet" href="<%= cssFile %>">
    <% }); %>
  <% } %>

  <!-- ========== FOOTER CSS (async — below the fold) ========== -->
  <link rel="preload" href="/css/footer.css" as="style" onload="this.onload=null;this.rel='stylesheet'">
  <noscript><link rel="stylesheet" href="/css/footer.css"></noscript>

  <!-- ========== GOOGLE ANALYTICS (async — non-blocking) ========== -->
  <% if (typeof gaMeasurementId !== 'undefined' && gaMeasurementId) { %>
  <script async src="https://www.googletagmanager.com/gtag/js?id=<%= gaMeasurementId %>"></script>
  <script nonce="<%= cspNonce %>">
    window.dataLayer = window.dataLayer || [];
    function gtag(){dataLayer.push(arguments);}
    gtag('js', new Date());
    gtag('config', '<%= gaMeasurementId %>', { send_page_view: true });
  </script>
  <% } %>

  <!-- ========== GOOGLE ADSENSE (verification meta — must be in head) ========== -->
  <meta name="google-adsense-account" content="<%= adsensePubId %>">
</head>
<body>
  <%- include('../partials/header') %>

  <main id="main-content">
    <%- body %>
  </main>

  <%- include('../partials/footer') %>

  <!-- ========== STRUCTURED DATA (JSON-LD) ========== -->
  <% if (typeof schema !== 'undefined' && schema) { %>
    <% if (Array.isArray(schema)) { %>
      <% schema.forEach(function(schemaItem) { %>
  <script type="application/ld+json"><%- JSON.stringify(schemaItem) %></script>
      <% }); %>
    <% } else { %>
  <script type="application/ld+json"><%- JSON.stringify(schema) %></script>
    <% } %>
  <% } %>

  <!-- ========== GLOBAL JS ========== -->
  <script src="/js/global.js" defer></script>
  <script src="/js/header.js" defer></script>

  <!-- ========== PAGE-SPECIFIC JS ========== -->
  <% if (typeof pageJS !== 'undefined' && Array.isArray(pageJS)) { %>
    <% pageJS.forEach(function(jsFile) { %>
  <script src="<%= jsFile %>" defer></script>
    <% }); %>
  <% } %>

  <!-- ========== DEVSAGE AI ASSISTANT WIDGET ========== -->
  <script src="https://api.devpilotx.com/widget.js" data-assistant="devsage" defer></script>

  <!-- ========== GOOGLE ADSENSE (deferred — loads after page is idle) ========== -->
  <% if (adsensePubId && adsensePubId !== 'ca-pub-XXXXXXXXXXXXXXXXX') { %>
  <script>
    (function() {
      function loadAdSense() {
        var s = document.createElement('script');
        s.async = true;
        s.crossOrigin = 'anonymous';
        s.src = 'https://pagead2.googlesyndication.com/pagead/js/adsbygoogle.js?client=<%= adsensePubId %>';
        document.head.appendChild(s);
      }
      if ('requestIdleCallback' in window) {
        requestIdleCallback(loadAdSense, { timeout: 4000 });
      } else {
        window.addEventListener('load', function() {
          setTimeout(loadAdSense, 1000);
        }, { once: true, passive: true });
      }
    })();
  </script>
  <% } %>
</body>
</html>
