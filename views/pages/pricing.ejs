<%# ============================================================ %>
<%# pricing.ejs — Pricing Page                                  %>
<%# ============================================================ %>

<div class="pricing-page">
  <section class="pricing-hero section-padding">
    <div class="container">
      <div class="pricing-hero__inner">
        <span class="section-number" aria-hidden="true">PRICING</span>
        <h1 class="pricing-hero__title">Simple, Honest Pricing</h1>
        <p class="pricing-hero__desc section-desc">
          All core tools are free, forever. Pro unlocks a better experience for developers who use Value.Codes daily.
        </p>
      </div>
    </div>
  </section>

  <section class="pricing-plans section-padding">
    <div class="container">
      <div class="pricing-grid">

        <!-- FREE PLAN -->
        <div class="pricing-card">
          <div class="pricing-card__header">
            <h2 class="pricing-card__name">Free</h2>
            <div class="pricing-card__price">
              <span class="pricing-card__amount">$0</span>
              <span class="pricing-card__period">forever</span>
            </div>
            <p class="pricing-card__tagline">Everything you need to ship code, free.</p>
          </div>
          <ul class="pricing-card__features">
            <li><svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><polyline points="20 6 9 17 4 12"/></svg> All developer tools — unlimited use</li>
            <li><svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><polyline points="20 6 9 17 4 12"/></svg> Online compiler — 19 languages</li>
            <li><svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><polyline points="20 6 9 17 4 12"/></svg> Full blog & resources access</li>
            <li><svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><polyline points="20 6 9 17 4 12"/></svg> Community access</li>
            <li><svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><polyline points="20 6 9 17 4 12"/></svg> No sign-up required for tools</li>
            <li class="pricing-card__feature--muted"><svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><line x1="18" y1="6" x2="6" y2="18"/><line x1="6" y1="6" x2="18" y2="18"/></svg> Ad-supported experience</li>
            <li class="pricing-card__feature--muted"><svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><line x1="18" y1="6" x2="6" y2="18"/><line x1="6" y1="6" x2="18" y2="18"/></svg> Standard compiler timeouts</li>
          </ul>
          <div class="pricing-card__cta">
            <a href="/register" class="btn btn-secondary">Get Started Free</a>
          </div>
        </div>

        <!-- PRO PLAN -->
        <div class="pricing-card pricing-card--pro">
          <div class="pricing-card__badge">Most Popular</div>
          <div class="pricing-card__header">
            <h2 class="pricing-card__name">Pro</h2>
            <div class="pricing-card__price">
              <span class="pricing-card__amount">$5</span>
              <span class="pricing-card__period">/ month</span>
            </div>
            <p class="pricing-card__tagline">The distraction-free developer experience.</p>
          </div>
          <ul class="pricing-card__features">
            <li><svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><polyline points="20 6 9 17 4 12"/></svg> Everything in Free</li>
            <li><svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><polyline points="20 6 9 17 4 12"/></svg> <strong>Zero ads</strong> — completely ad-free</li>
            <li><svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><polyline points="20 6 9 17 4 12"/></svg> Extended compiler execution limits</li>
            <li><svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><polyline points="20 6 9 17 4 12"/></svg> Pro badge on community profile</li>
            <li><svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><polyline points="20 6 9 17 4 12"/></svg> Priority support response</li>
            <li><svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><polyline points="20 6 9 17 4 12"/></svg> Exclusive Pro community channels</li>
            <li><svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><polyline points="20 6 9 17 4 12"/></svg> Early access to new tools</li>
          </ul>
          <div class="pricing-card__cta">
            <a href="/register" class="btn btn-primary">Start Pro — $5/mo</a>
          </div>
        </div>

      </div>

      <p class="pricing-note">All prices in USD. Cancel anytime. Switching between plans takes effect at the next billing cycle.</p>
    </div>
  </section>

  <section class="pricing-faq section-padding">
    <div class="container">
      <h2 class="pricing-faq__title">Frequently Asked Questions</h2>
      <div class="pricing-faq__grid">
        <details class="pricing-faq__item">
          <summary class="pricing-faq__q">Do the free tools ever expire or get limited?</summary>
          <p class="pricing-faq__a">No. All core tools are free forever with no usage caps. Free users see ads to support the platform, but the tools themselves are fully functional.</p>
        </details>
        <details class="pricing-faq__item">
          <summary class="pricing-faq__q">What payment methods are accepted?</summary>
          <p class="pricing-faq__a">We accept all major credit cards and debit cards via Stripe. Billing is monthly with no long-term commitment required.</p>
        </details>
        <details class="pricing-faq__item">
          <summary class="pricing-faq__q">Can I cancel Pro at any time?</summary>
          <p class="pricing-faq__a">Yes, you can cancel Pro from your account settings at any time. Your Pro access continues until the end of the current billing period.</p>
        </details>
        <details class="pricing-faq__item">
          <summary class="pricing-faq__q">Is there a student or team discount?</summary>
          <p class="pricing-faq__a">We're working on team plans. For student discounts or special arrangements, <a href="/contact/">contact us</a> and we'll work something out.</p>
        </details>
      </div>
    </div>
  </section>
</div>
