<%# ============================================================ %>
<%# newsletter.ejs  |  Newsletter Signup Page                     %>
<%# ============================================================ %>

<div class="newsletter-page">
  <section class="newsletter-hero section-padding">
    <div class="container">
      <div class="newsletter-hero__inner">
        <span class="section-number" aria-hidden="true">NEWSLETTER</span>
        <h1 class="newsletter-hero__title">Developer Insights, Weekly</h1>
        <p class="newsletter-hero__desc section-desc">
          The Value.Codes newsletter delivers curated developer tips, tool updates, deep-dive articles, and career insights every week. No spam. Unsubscribe any time.
        </p>

        <% if (typeof success !== 'undefined' && success) { %>
        <div class="newsletter-success" role="alert">
          <span>You're subscribed! Check your inbox for a confirmation email.</span>
        </div>
        <% } else { %>

        <form class="newsletter-form" action="/newsletter" method="POST" novalidate>
          <% if (typeof errors !== 'undefined' && errors.length > 0) { %>
          <div class="form-errors" role="alert">
            <% errors.forEach(function(err) { %><p class="form-error-msg"><%= err.msg %></p><% }); %>
          </div>
          <% } %>

          <div class="newsletter-form__row">
            <div class="form-group">
              <label for="nl-name" class="form-label">Your Name</label>
              <input type="text" id="nl-name" name="name" class="form-input" placeholder="Alex Chen" autocomplete="given-name" required>
            </div>
            <div class="form-group">
              <label for="nl-email" class="form-label">Email Address <span class="form-required" aria-label="required">*</span></label>
              <input type="email" id="nl-email" name="email" class="form-input" placeholder="you@example.com" autocomplete="email" required>
            </div>
          </div>

          <!-- Honeypot -->
          <div class="form-honeypot" aria-hidden="true">
            <input type="text" name="website" tabindex="-1" autocomplete="off">
          </div>

          <button type="submit" class="btn btn-primary newsletter-form__btn">Subscribe for Free</button>
          <p class="newsletter-form__note">No spam. Unsubscribe with one click at any time.</p>
        </form>

        <% } %>
      </div>
    </div>
  </section>


  <section class="newsletter-features section-padding">
    <div class="container">
      <div class="newsletter-features__grid">
        <div class="newsletter-feature">
          <span class="newsletter-feature__label">01</span>
          <h3>Deep-Dive Articles</h3>
          <p>Long-form technical articles on architecture, performance, and the tools shaping modern development.</p>
        </div>
        <div class="newsletter-feature">
          <span class="newsletter-feature__label">02</span>
          <h3>Tool Updates</h3>
          <p>First to know when new tools launch on Value.Codes, with tutorials on getting the most out of them.</p>
        </div>
        <div class="newsletter-feature">
          <span class="newsletter-feature__label">03</span>
          <h3>Curated Links</h3>
          <p>Hand-picked resources, libraries, and threads from the developer community worth reading each week.</p>
        </div>
        <div class="newsletter-feature">
          <span class="newsletter-feature__label">04</span>
          <h3>Career Tips</h3>
          <p>Actionable career advice for developers at every stage: interviews, promotions, freelancing, and beyond.</p>
        </div>
      </div>
    </div>
  </section>
</div>
