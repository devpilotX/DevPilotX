<%# ============================================================ %>
<%# search.ejs — Search Results Page                            %>
<%# ============================================================ %>

<div class="search-page">
  <section class="search-hero section-padding">
    <div class="container">
      <h1 class="search-hero__title">Search Value.Codes</h1>
      <form class="search-form" action="/search/" method="GET" role="search">
        <div class="search-form__wrap">
          <svg class="search-form__icon" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
            <circle cx="11" cy="11" r="8"/><path d="M21 21l-4.35-4.35"/>
          </svg>
          <input
            type="search"
            name="q"
            class="search-form__input"
            value="<%= typeof query !== 'undefined' ? query : '' %>"
            placeholder="Search tools, articles, resources..."
            aria-label="Search Value.Codes"
            autofocus
          >
          <button type="submit" class="btn btn-primary search-form__btn">Search</button>
        </div>
      </form>
    </div>
  </section>
<!-- ========== ADSENSE: LEADERBOARD ========== -->
<% if (adsensePubId && adsensePubId !== 'ca-pub-XXXXXXXXXXXXXXXXX') { %>
<div class="ad-leaderboard" aria-label="Advertisement">
  <ins class="adsbygoogle"
       style="display:block"
       data-ad-client="<%= adsensePubId %>"
       data-ad-slot="auto"
       data-ad-format="auto"
       data-full-width-responsive="true"></ins>
</div>
<% } %>


  <section class="search-results section-padding">
    <div class="container">
      <% if (typeof query !== 'undefined' && query.trim()) { %>
        <p class="search-results__query">Showing results for: <strong>"<%= query %>"</strong></p>
        <div class="search-results__list">
          <p class="search-results__empty">No results found. Try a different search term, or browse our <a href="/tools/">tools</a>, <a href="/blog/">blog</a>, or <a href="/resources/">resources</a>.</p>
        </div>
      <% } else { %>
        <div class="search-suggestions">
          <h2>Popular Searches</h2>
          <div class="search-suggestions__tags">
            <a href="/search?q=json" class="tag">JSON Formatter</a>
            <a href="/search?q=regex" class="tag">Regex Builder</a>
            <a href="/search?q=compiler" class="tag">Online Compiler</a>
            <a href="/search?q=base64" class="tag">Base64</a>
            <a href="/search?q=jwt" class="tag">JWT Decoder</a>
            <a href="/search?q=hash" class="tag">Hash Generator</a>
            <a href="/search?q=css" class="tag">CSS Tools</a>
            <a href="/search?q=api" class="tag">API</a>
          </div>
          <div class="search-quick-links">
            <h3>Browse by Section</h3>
            <div class="search-quick-links__grid">
              <a href="/tools/" class="search-quick-link">
                <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><polyline points="16 18 22 12 16 6"/><polyline points="8 6 2 12 8 18"/></svg>
                <span>All Tools</span>
              </a>
              <a href="/blog/" class="search-quick-link">
                <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M4 19.5A2.5 2.5 0 0 1 6.5 17H20"/><path d="M6.5 2H20v20H6.5A2.5 2.5 0 0 1 4 19.5v-15A2.5 2.5 0 0 1 6.5 2z"/></svg>
                <span>Blog</span>
              </a>
              <a href="/resources/" class="search-quick-link">
                <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M2 3h6a4 4 0 0 1 4 4v14a3 3 0 0 0-3-3H2z"/><path d="M22 3h-6a4 4 0 0 0-4 4v14a3 3 0 0 1 3-3h7z"/></svg>
                <span>Resources</span>
              </a>
              <a href="/compiler/" class="search-quick-link">
                <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><polyline points="16 18 22 12 16 6"/><polyline points="8 6 2 12 8 18"/></svg>
                <span>Compiler</span>
              </a>
            </div>
          </div>
        </div>
      <% } %>
    </div>
  </section>
</div>
