  <!-- ================================================================
       [03] HOW TO CONTRIBUTE — STEPS
       ================================================================ -->
  <section class="content-section" id="how-to-contribute"
           aria-labelledby="how-heading">
    <div class="section-header">
      <span class="section-number">02</span>
      <h2 id="how-heading">How to Contribute</h2>
    </div>
    <p class="section-desc">
      Get your first pull request merged in minutes with these four steps.
    </p>

    <div class="contribute-steps">

      <div class="contribute-step">
        <div class="contribute-step__number" aria-hidden="true">1</div>
        <div class="contribute-step__content">
          <h3>Fork &amp; Clone the Repository</h3>
          <p>Start by forking the repo on GitHub, then clone your fork locally.</p>
          <div class="contribute-step__code">
            <code>git clone https://github.com/YOUR-USERNAME/value-codes-platform.git
cd value-codes-platform</code>
            <button class="contribute-copy-btn"
                    data-copy="git clone https://github.com/YOUR-USERNAME/value-codes-platform.git&#10;cd value-codes-platform"
                    aria-label="Copy code" type="button">
              <svg width="15" height="15" viewBox="0 0 24 24" fill="none"
                   stroke="currentColor" stroke-width="2" aria-hidden="true">
                <rect x="9" y="9" width="13" height="13" rx="2" ry="2"/>
                <path d="M5 15H4a2 2 0 0 1-2-2V4a2 2 0 0 1 2-2h9a2 2 0 0 1 2 2v1"/>
              </svg>
            </button>
          </div>
        </div>
      </div>

      <div class="contribute-step">
        <div class="contribute-step__number" aria-hidden="true">2</div>
        <div class="contribute-step__content">
          <h3>Install Dependencies</h3>
          <p>Install all required packages with npm.</p>
          <div class="contribute-step__code">
            <code>npm install</code>
            <button class="contribute-copy-btn"
                    data-copy="npm install"
                    aria-label="Copy code" type="button">
              <svg width="15" height="15" viewBox="0 0 24 24" fill="none"
                   stroke="currentColor" stroke-width="2" aria-hidden="true">
                <rect x="9" y="9" width="13" height="13" rx="2" ry="2"/>
                <path d="M5 15H4a2 2 0 0 1-2-2V4a2 2 0 0 1 2-2h9a2 2 0 0 1 2 2v1"/>
              </svg>
            </button>
          </div>
        </div>
      </div>

      <div class="contribute-step">
        <div class="contribute-step__number" aria-hidden="true">3</div>
        <div class="contribute-step__content">
          <h3>Create a Feature Branch</h3>
          <p>Always work on a new branch — never commit directly to <code>main</code>.</p>
          <div class="contribute-step__code">
            <code>git checkout -b feature/your-feature-name</code>
            <button class="contribute-copy-btn"
                    data-copy="git checkout -b feature/your-feature-name"
                    aria-label="Copy code" type="button">
              <svg width="15" height="15" viewBox="0 0 24 24" fill="none"
                   stroke="currentColor" stroke-width="2" aria-hidden="true">
                <rect x="9" y="9" width="13" height="13" rx="2" ry="2"/>
                <path d="M5 15H4a2 2 0 0 1-2-2V4a2 2 0 0 1 2-2h9a2 2 0 0 1 2 2v1"/>
              </svg>
            </button>
          </div>
        </div>
      </div>

      <div class="contribute-step">
        <div class="contribute-step__number" aria-hidden="true">4</div>
        <div class="contribute-step__content">
          <h3>Commit &amp; Open a Pull Request</h3>
          <p>Push your branch and open a PR on GitHub. Reference the related
          issue with <code>#issue-number</code> in your PR description.</p>
          <div class="contribute-step__code">
            <code>git add .
git commit -m "feat: describe your change"
git push origin feature/your-feature-name</code>
            <button class="contribute-copy-btn"
                    data-copy="git add .&#10;git commit -m &quot;feat: describe your change&quot;&#10;git push origin feature/your-feature-name"
                    aria-label="Copy code" type="button">
              <svg width="15" height="15" viewBox="0 0 24 24" fill="none"
                   stroke="currentColor" stroke-width="2" aria-hidden="true">
                <rect x="9" y="9" width="13" height="13" rx="2" ry="2"/>
                <path d="M5 15H4a2 2 0 0 1-2-2V4a2 2 0 0 1 2-2h9a2 2 0 0 1 2 2v1"/>
              </svg>
            </button>
          </div>
        </div>
      </div>

    </div>
  </section>


