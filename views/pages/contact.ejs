<%# ============================================================ %>
<%# contact.ejs — Contact Page                                   %>
<%# Functional contact form with validation and feedback         %>
<%# ============================================================ %>

<section class="contact-hero">
  <div class="container">
    <div class="contact-hero__inner">
      <span class="section-number" aria-hidden="true">CONTACT</span>
      <h1 class="contact-hero__title">Get in Touch</h1>
      <p class="contact-hero__desc">
        Have a question, found a bug, or want to suggest a feature? We read every message and typically respond within 24 hours.
      </p>
    </div>
  </div>
</section>

<!-- ===== ADSENSE: LEADERBOARD ===== -->
<% if (adsensePubId && adsensePubId !== 'ca-pub-XXXXXXXXXXXXXXXXX') { %>
<div class="ad-leaderboard" aria-label="Advertisement">
  <ins class="adsbygoogle"
       style="display:block"
       data-ad-client="<%= adsensePubId %>"
       data-ad-slot="auto"
       data-ad-format="auto"
       data-full-width-responsive="true"></ins>
</div>
<% } %>

<section class="contact-body">
  <div class="container">
    <div class="contact-layout">

      <!-- ===== LEFT: CONTACT FORM ===== -->
      <div class="contact-form-wrap">

        <% if (typeof success !== 'undefined' && success) { %>
        <div class="contact-success" role="alert">
          <div class="contact-success__icon" aria-hidden="true">
            <svg width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M22 11.08V12a10 10 0 1 1-5.93-9.14"/><polyline points="22 4 12 14.01 9 11.01"/></svg>
          </div>
          <div>
            <h3 class="contact-success__title">Message sent!</h3>
            <p class="contact-success__text">Thanks for reaching out. We'll get back to you within 24 hours.</p>
          </div>
        </div>
        <% } %>

        <% if (typeof errors !== 'undefined' && errors && errors.length > 0) { %>
        <div class="contact-errors" role="alert">
          <ul>
            <% errors.forEach(function(e) { %>
              <li><%= e.msg || e %></li>
            <% }); %>
          </ul>
        </div>
        <% } %>

        <% if (typeof success === 'undefined' || !success) { %>
        <form
          class="contact-form"
          id="contact-form"
          method="POST"
          action="/contact/"
          novalidate
          aria-label="Contact form"
        >

          <div class="form-row form-row--2">
            <div class="form-group">
              <label class="form-label" for="contact-name">Full Name <span class="form-required" aria-hidden="true">*</span></label>
              <input
                type="text"
                id="contact-name"
                name="name"
                class="form-input"
                placeholder="Your Name"
                autocomplete="name"
                required
                minlength="2"
                maxlength="100"
                aria-required="true"
              >
              <span class="form-error" id="name-error" aria-live="polite"></span>
            </div>

            <div class="form-group">
              <label class="form-label" for="contact-email">Email Address <span class="form-required" aria-hidden="true">*</span></label>
              <input
                type="email"
                id="contact-email"
                name="email"
                class="form-input"
                placeholder="you@example.com"
                autocomplete="email"
                required
                maxlength="254"
                aria-required="true"
              >
              <span class="form-error" id="email-error" aria-live="polite"></span>
            </div>
          </div>

          <div class="form-group">
            <label class="form-label" for="contact-subject">Subject <span class="form-required" aria-hidden="true">*</span></label>
            <select id="contact-subject" name="subject" class="form-select" required aria-required="true">
              <option value="" disabled selected>Select a topic…</option>
              <option value="Bug Report">Bug Report</option>
              <option value="Feature Request">Feature Request</option>
              <option value="General Question">General Question</option>
              <option value="Business Inquiry">Business Inquiry</option>
              <option value="Tool Feedback">Tool Feedback</option>
              <option value="Blog Suggestion">Blog Suggestion</option>
              <option value="Other">Other</option>
            </select>
            <span class="form-error" id="subject-error" aria-live="polite"></span>
          </div>

          <div class="form-group">
            <label class="form-label" for="contact-message">Message <span class="form-required" aria-hidden="true">*</span></label>
            <textarea
              id="contact-message"
              name="message"
              class="form-textarea"
              placeholder="Describe your question or feedback in detail…"
              rows="6"
              required
              minlength="20"
              maxlength="3000"
              aria-required="true"
            ></textarea>
            <div class="form-meta">
              <span class="form-error" id="message-error" aria-live="polite"></span>
              <span class="form-char-count" id="char-count" aria-live="polite">0 / 3000</span>
            </div>
          </div>

          <div class="form-group form-honeypot" aria-hidden="true">
            <label for="contact-website">Website</label>
            <input type="text" id="contact-website" name="website" tabindex="-1" autocomplete="off">
          </div>

          <button type="submit" class="btn btn-primary btn-lg contact-submit" id="contact-submit">
            <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><line x1="22" y1="2" x2="11" y2="13"/><polygon points="22 2 15 22 11 13 2 9 22 2"/></svg>
            <span id="submit-text">Send Message</span>
          </button>

        </form>
        <% } %>
      </div>

      <!-- ===== RIGHT: CONTACT INFO ===== -->
      <aside class="contact-info" aria-label="Contact information">

        <div class="contact-info-card">
          <div class="contact-info-card__icon" aria-hidden="true">
            <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M4 4h16c1.1 0 2 .9 2 2v12c0 1.1-.9 2-2 2H4c-1.1 0-2-.9-2-2V6c0-1.1.9-2 2-2z"/><polyline points="22,6 12,13 2,6"/></svg>
          </div>
          <div>
            <h3 class="contact-info-card__title">Email Us</h3>
            <p class="contact-info-card__text">For support and general inquiries</p>
            <a href="mailto:hello@value.codes" class="contact-info-card__link">hello@value.codes</a>
          </div>
        </div>

        <div class="contact-info-card">
          <div class="contact-info-card__icon" aria-hidden="true">
            <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"/><polyline points="12 6 12 12 16 14"/></svg>
          </div>
          <div>
            <h3 class="contact-info-card__title">Response Time</h3>
            <p class="contact-info-card__text">We aim to respond to every message within 24 hours on weekdays. Weekends may take a little longer.</p>
          </div>
        </div>

        <div class="contact-info-card">
          <div class="contact-info-card__icon" aria-hidden="true">
            <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/></svg>
          </div>
          <div>
            <h3 class="contact-info-card__title">Bug Reports</h3>
            <p class="contact-info-card__text">Found something broken? Use the form and select "Bug Report" — include the tool name and steps to reproduce.</p>
          </div>
        </div>

        <div class="contact-social-block">
          <h3 class="contact-social-block__title">Reach Us On</h3>
          <div class="contact-social-links">
            <a href="https://twitter.com/value_codes" target="_blank" rel="noopener noreferrer" class="contact-social-link" aria-label="Twitter / X">
              <svg width="16" height="16" fill="currentColor" viewBox="0 0 24 24" aria-hidden="true"><path d="M18.244 2.25h3.308l-7.227 8.26 8.502 11.24H16.17l-4.714-6.231-5.401 6.231H2.742l7.731-8.835L1.254 2.25H8.08l4.253 5.622zm-1.161 17.52h1.833L7.084 4.126H5.117z"/></svg>
              Twitter / X
            </a>
            <a href="https://github.com/Value-Codes" target="_blank" rel="noopener noreferrer" class="contact-social-link" aria-label="GitHub">
              <svg width="16" height="16" fill="currentColor" viewBox="0 0 24 24" aria-hidden="true"><path d="M12 0c-6.626 0-12 5.373-12 12 0 5.302 3.438 9.8 8.207 11.387.599.111.793-.261.793-.577v-2.234c-3.338.726-4.033-1.416-4.033-1.416-.546-1.387-1.333-1.756-1.333-1.756-1.089-.745.083-.729.083-.729 1.205.084 1.839 1.237 1.839 1.237 1.07 1.834 2.807 1.304 3.492.997.107-.775.418-1.305.762-1.604-2.665-.305-5.467-1.334-5.467-5.931 0-1.311.469-2.381 1.236-3.221-.124-.303-.535-1.524.117-3.176 0 0 1.008-.322 3.301 1.23.957-.266 1.983-.399 3.003-.404 1.02.005 2.047.138 3.006.404 2.291-1.552 3.297-1.23 3.297-1.23.653 1.653.242 2.874.118 3.176.77.84 1.235 1.911 1.235 3.221 0 4.609-2.807 5.624-5.479 5.921.43.372.823 1.102.823 2.222v3.293c0 .319.192.694.801.576 4.765-1.589 8.199-6.086 8.199-11.386 0-6.627-5.373-12-12-12z"/></svg>
              GitHub
            </a>
          </div>
        </div>

        <div class="contact-faq">
          <h3 class="contact-faq__title">Quick Answers</h3>
          <div class="contact-faq__list">
            <details class="contact-faq__item">
              <summary class="contact-faq__question">Is Value.Codes free?</summary>
              <p class="contact-faq__answer">Yes. All tools are completely free to use with no account required. We offer a Pro plan with extra perks like an ad-free experience.</p>
            </details>
            <details class="contact-faq__item">
              <summary class="contact-faq__question">Do you store data I paste into tools?</summary>
              <p class="contact-faq__answer">No. All tools process data locally in your browser. Nothing is sent to our servers.</p>
            </details>
            <details class="contact-faq__item">
              <summary class="contact-faq__question">Can I contribute a tool or article?</summary>
              <p class="contact-faq__answer">Absolutely. Use the contact form with subject "Feature Request" or visit our <a href="/contribute/">Contribute page</a> for details.</p>
            </details>
          </div>
        </div>

      </aside>
    </div>
  </div>
</section>
