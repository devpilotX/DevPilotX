            <span class="code-line">}</span>
          </div>
        </div>

        <!-- JavaScript Snippet -->
        <div class="snippet-preview">
          <div class="snippet-preview-header">
            <span class="snippet-lang-badge snippet-lang-badge--js">JS</span>
            <span class="snippet-preview-name">Debounce Function</span>
            <span class="snippet-copy-hint" aria-hidden="true">copy</span>
          </div>
          <div class="snippet-preview-code">
            <span class="code-line"><span class="c-keyword">const</span> <span class="c-function">debounce</span> = (fn, ms) => {</span>
            <span class="code-line">&nbsp;&nbsp;<span class="c-keyword">let</span> timer;</span>
            <span class="code-line">&nbsp;&nbsp;<span class="c-keyword">return</span> (...args) => {</span>
            <span class="code-line">&nbsp;&nbsp;&nbsp;&nbsp;<span class="c-function">clearTimeout</span>(timer);</span>
            <span class="code-line">&nbsp;&nbsp;&nbsp;&nbsp;timer = <span class="c-function">setTimeout</span>(</span>
            <span class="code-line">&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;() => <span class="c-function">fn</span>(...args), ms);</span>
            <span class="code-line">&nbsp;&nbsp;};</span>
            <span class="code-line">};</span>
          </div>
        </div>

        <!-- Node.js Snippet -->
        <div class="snippet-preview snippet-preview--featured">
          <div class="snippet-preview-header">
            <span class="snippet-lang-badge snippet-lang-badge--node">Node.js</span>
            <span class="snippet-preview-name">Express Logger</span>
            <span class="snippet-copy-hint" aria-hidden="true">copy</span>
          </div>
          <div class="snippet-preview-code">
            <span class="code-line"><span class="c-keyword">const</span> logger = (req, res, next) => {</span>
            <span class="code-line">&nbsp;&nbsp;<span class="c-keyword">const</span> start = <span class="c-function">Date.now</span>();</span>
            <span class="code-line">&nbsp;&nbsp;<span class="c-function">res.on</span>(<span class="c-string">'finish'</span>, () => {</span>
            <span class="code-line">&nbsp;&nbsp;&nbsp;&nbsp;console.<span class="c-function">log</span>(`${req.<span class="c-keyword">method</span>}</span>
            <span class="code-line">&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;${req.<span class="c-keyword">url</span>} <span class="c-number">${Date.now()-start}</span>ms`);</span>
            <span class="code-line">&nbsp;&nbsp;});</span>
            <span class="code-line">&nbsp;&nbsp;<span class="c-function">next</span>();</span>
            <span class="code-line">};</span>
          </div>
        </div>

      </div>

