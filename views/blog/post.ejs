<%# ============================================================ %>
<%# blog/post.ejs — Universal Blog Post Layout                   %>
<%# ============================================================ %>

<div class="blog-post-page" aria-label="Blog article: <%= blog.title %>">

  <% if (adsensePubId && adsensePubId !== 'ca-pub-XXXXXXXXXXXXXXXXX') { %>
  <div class="ad-leaderboard" aria-label="Advertisement">
    <ins class="adsbygoogle"
         style="display:block"
         data-ad-client="<%= adsensePubId %>"
         data-ad-slot="auto"
         data-ad-format="auto"
         data-full-width-responsive="true"></ins>
    <script>(adsbygoogle = window.adsbygoogle || []).push({});</script>
  </div>
  <% } %>

  <%# ========== ARTICLE HEADER ========== %>
  <section class="blog-post-hero" aria-label="Article header">
    <div class="container">
      <nav class="blog-breadcrumb" aria-label="Breadcrumb">
        <ol class="blog-breadcrumb__list">
          <li class="blog-breadcrumb__item"><a href="/">Home</a></li>
          <li class="blog-breadcrumb__item"><a href="/blog/">Blog</a></li>
          <li class="blog-breadcrumb__item" aria-current="page"><%= blog.title %></li>
        </ol>
      </nav>

      <div class="blog-post-header">
        <% if (blog.category_name) { %><span class="badge badge-pill"><%= blog.category_name %></span><% } %>
        <h1 class="blog-post__title"><%= blog.title %></h1>
        <p class="blog-post__subtitle"><%= blog.summary || '' %></p>
      </div>
    </div>
  </section>

  <%# ========== ARTICLE BODY ========== %>
  <section class="blog-post-content section-padding" aria-label="Article content">
    <div class="container">
      <div class="blog-post-layout">

        <%# ========== MAIN ARTICLE ========== %>
        <article class="blog-article" aria-label="Article body">

          <%# ========== HERO IMAGE ========== %>
          <figure class="blog-post__hero-image">
            <img
              src="<%= blog.thumbnail || '/images/blog/placeholder.svg' %>"
              alt="<%= blog.title %>"
              width="800"
              height="450"
              loading="eager"
              fetchpriority="high"
              decoding="async"
              class="blog-post__image"
              onerror="this.onerror=null;this.src='/images/blog/placeholder.svg'"
            >
          </figure>

          <% if (adsensePubId && adsensePubId !== 'ca-pub-XXXXXXXXXXXXXXXXX') { %>
          <div class="ad-in-article">
            <ins class="adsbygoogle"
                 style="display:block; text-align:center;"
                 data-ad-layout="in-article"
                 data-ad-format="fluid"
                 data-ad-client="<%= adsensePubId %>"
                 data-ad-slot="auto"></ins>
            <script>(adsbygoogle = window.adsbygoogle || []).push({});</script>
          </div>
          <% } %>

          <%# ========== BLOG POST CONTENT ========== %>
          <div class="blog-article__body">
            <%- article ? article.content : (blog ? blog.content : '') %>
          </div>

          <% if (adsensePubId && adsensePubId !== 'ca-pub-XXXXXXXXXXXXXXXXX') { %>
          <div class="ad-in-article">
            <ins class="adsbygoogle"
                 style="display:block; text-align:center;"
                 data-ad-layout="in-article"
                 data-ad-format="fluid"
                 data-ad-client="<%= adsensePubId %>"
                 data-ad-slot="auto"></ins>
            <script>(adsbygoogle = window.adsbygoogle || []).push({});</script>
          </div>
          <% } %>

          <%# ========== AUTHOR META (bottom) ========== %>
          <div class="blog-post__meta blog-post__meta--bottom">
            <div class="blog-post__author">
              <div class="blog-post__avatar" aria-hidden="true">
                <%= (blog.author || 'A').charAt(0).toUpperCase() %>
              </div>
              <div class="blog-post__author-info">
                <span class="blog-post__author-name"><%= blog.author %></span>
                <div class="blog-post__date-info">
                  <time datetime="<%= blog.published_at || '' %>"><%= blog.formattedDate %></time>
                  <span class="blog-card__dot" aria-hidden="true">&middot;</span>
                  <span><%= blog.readTime %></span>
                </div>
              </div>
            </div>
            <div class="blog-post__share" aria-label="Share this article">
              <button class="blog-share-btn" type="button" data-share="twitter" aria-label="Share on Twitter">
                <svg width="20" height="20" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true"><path d="M18.244 2.25h3.308l-7.227 8.26 8.502 11.24H16.17l-5.214-6.817L4.99 21.75H1.68l7.73-8.835L1.254 2.25H8.08l4.713 6.231zm-1.161 17.52h1.833L7.084 4.126H5.117z"/></svg>
              </button>
              <button class="blog-share-btn" type="button" data-share="linkedin" aria-label="Share on LinkedIn">
                <svg width="20" height="20" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true"><path d="M20.447 20.452h-3.554v-5.569c0-1.328-.027-3.037-1.852-3.037-1.853 0-2.136 1.445-2.136 2.939v5.667H9.351V9h3.414v1.561h.046c.477-.9 1.637-1.85 3.37-1.85 3.601 0 4.267 2.37 4.267 5.455v6.286zM5.337 7.433c-1.144 0-2.063-.926-2.063-2.065 0-1.138.92-2.063 2.063-2.063 1.14 0 2.064.925 2.064 2.063 0 1.139-.925 2.065-2.064 2.065zm1.782 13.019H3.555V9h3.564v11.452zM22.225 0H1.771C.792 0 0 .774 0 1.729v20.542C0 23.227.792 24 1.771 24h20.451C23.2 24 24 23.227 24 22.271V1.729C24 .774 23.2 0 22.222 0h.003z"/></svg>
              </button>
              <button class="blog-share-btn" type="button" data-share="copy" aria-label="Copy article link">
                <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M10 13a5 5 0 0 0 7.54.54l3-3a5 5 0 0 0-7.07-7.07l-1.72 1.71"></path><path d="M14 11a5 5 0 0 0-7.54-.54l-3 3a5 5 0 0 0 7.07 7.07l1.71-1.71"></path></svg>
              </button>
            </div>
          </div>

          <%# ========== ARTICLE TAGS ========== %>
          <div class="blog-post__footer-tags">
            <span class="blog-post__tags-label">Tags:</span>
            <% (blog.tags || []).forEach(function(tag) { %>
              <span class="tag"><%= tag %></span>
            <% }); %>
          </div>

          <%# ========== SHARE BOTTOM BAR ========== %>
          <div class="blog-post__share-bottom">
            <p>Found this article helpful? Share it with your network:</p>
            <div class="blog-post__share" aria-label="Share this article">
              <button class="blog-share-btn btn btn-secondary btn-sm" type="button" data-share="twitter" aria-label="Share on Twitter">
                Share on X
              </button>
              <button class="blog-share-btn btn btn-secondary btn-sm" type="button" data-share="linkedin" aria-label="Share on LinkedIn">
                Share on LinkedIn
              </button>
              <button class="blog-share-btn btn btn-ghost btn-sm" type="button" data-share="copy" aria-label="Copy link">
                Copy Link
              </button>
            </div>
          </div>

          <%# ========== PREV/NEXT NAVIGATION ========== %>
          <nav class="blog-post-nav" aria-label="Previous and next articles">
            <% if (prevPost) { %>
              <a href="/blog/<%= prevPost.slug %>/" class="blog-post-nav__link blog-post-nav__link--prev">
                <span class="blog-post-nav__label">&larr; Previous Article</span>
                <span class="blog-post-nav__title"><%= prevPost.title %></span>
              </a>
            <% } else { %>
              <div></div>
            <% } %>
            <% if (nextPost) { %>
              <a href="/blog/<%= nextPost.slug %>/" class="blog-post-nav__link blog-post-nav__link--next">
                <span class="blog-post-nav__label">Next Article &rarr;</span>
                <span class="blog-post-nav__title"><%= nextPost.title %></span>
              </a>
            <% } %>
          </nav>

        </article>

        <%# ========== SIDEBAR ========== %>
        <aside class="blog-sidebar blog-sidebar--post" aria-label="Article sidebar">

          <% if (adsensePubId && adsensePubId !== 'ca-pub-XXXXXXXXXXXXXXXXX') { %>
          <div class="blog-widget blog-widget--ad">
            <ins class="adsbygoogle"
                 style="display:block"
                 data-ad-client="<%= adsensePubId %>"
                 data-ad-slot="auto"
                 data-ad-format="auto"
                 data-full-width-responsive="true"></ins>
            <script>(adsbygoogle = window.adsbygoogle || []).push({});</script>
          </div>
          <% } %>

          <%# ========== TABLE OF CONTENTS ========== %>
          <div class="blog-widget blog-widget--toc">
            <h3 class="blog-widget__title">Table of Contents</h3>
            <nav class="blog-toc" aria-label="Table of contents" data-blog-toc>
              <%# TOC is generated dynamically by blog.js %>
            </nav>
          </div>

          <%# ========== NEWSLETTER WIDGET ========== %>
          <div class="blog-widget blog-widget--newsletter">
            <h3 class="blog-widget__title">Stay Updated</h3>
            <p class="blog-widget__desc">Get the latest articles delivered to your inbox.</p>
            <a href="/newsletter/" class="btn btn-primary btn-sm">Subscribe</a>
          </div>

          <%# ========== RELATED POSTS ========== %>
          <% if (relatedPosts && relatedPosts.length > 0) { %>
          <div class="blog-widget">
            <h3 class="blog-widget__title">Related Articles</h3>
            <ul class="blog-widget__related">
              <% relatedPosts.forEach(function(rp) { %>
                <li class="blog-widget__related-item">
                  <a href="/blog/<%= rp.slug %>/">
                    <span class="blog-widget__related-title"><%= rp.title %></span>
                    <span class="blog-widget__related-date"><%= rp.formattedDate %></span>
                  </a>
                </li>
              <% }); %>
            </ul>
          </div>
          <% } %>

        </aside>
      </div>
    </div>
  </section>

  <% if (adsensePubId && adsensePubId !== 'ca-pub-XXXXXXXXXXXXXXXXX') { %>
  <div class="ad-leaderboard" aria-label="Advertisement">
    <ins class="adsbygoogle"
         style="display:block"
         data-ad-client="<%= adsensePubId %>"
         data-ad-slot="auto"
         data-ad-format="auto"
         data-full-width-responsive="true"></ins>
    <script>(adsbygoogle = window.adsbygoogle || []).push({});</script>
  </div>
  <% } %>

</div>
