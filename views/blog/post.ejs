<%# ============================================================ %>
<%# blog/post.ejs — Blog Post Layout (Industry Grade)           %>
<%# ============================================================ %>

<%# ─── Reading Progress Bar ─── %>
<div class="blog-progress-bar" id="blogProgressBar" role="progressbar" aria-label="Reading progress" aria-valuemin="0" aria-valuemax="100" aria-valuenow="0" aria-hidden="true"></div>

<div class="blog-post-page">

  <% if (adsensePubId && adsensePubId !== 'ca-pub-XXXXXXXXXXXXXXXXX') { %>
  <div class="ad-leaderboard" aria-label="Advertisement">
    <ins class="adsbygoogle"
         style="display:block"
         data-ad-client="<%= adsensePubId %>"
         data-ad-slot="auto"
         data-ad-format="auto"
         data-full-width-responsive="true"></ins>
  </div>
  <% } %>

  <%# ─── ARTICLE HEADER ─── %>
  <header class="blog-post-hero" aria-label="Article header">
    <div class="container">

      <nav class="blog-breadcrumb" aria-label="Breadcrumb">
        <ol class="blog-breadcrumb__list">
          <li class="blog-breadcrumb__item"><a href="/">Home</a></li>
          <li class="blog-breadcrumb__item"><a href="/blog/">Blog</a></li>
          <li class="blog-breadcrumb__item" aria-current="page"><%= blog.title %></li>
        </ol>
      </nav>

      <div class="blog-post-header">

        <% if (blog.category_name) { %>
        <a href="/blog/category/<%= blog.category_slug %>/" class="blog-post__cat-link" tabindex="-1">
          <span class="badge badge-pill"><%= blog.category_name %></span>
        </a>
        <% } %>

        <h1 class="blog-post__title"><%= blog.title %></h1>

        <% if (blog.summary) { %>
        <p class="blog-post__subtitle"><%= blog.summary %></p>
        <% } %>

        <div class="blog-post__meta">
          <div class="blog-post__author">
            <div class="blog-post__avatar" aria-hidden="true">
              <%= (blog.author || 'V').charAt(0).toUpperCase() %>
            </div>
            <div class="blog-post__author-info">
              <span class="blog-post__author-name"><%= blog.author %></span>
              <div class="blog-post__date-info">
                <time datetime="<%= blog.published_at || '' %>"><%= blog.formattedDate %></time>
                <span aria-hidden="true" class="blog-post__dot">&middot;</span>
                <span><%= blog.readTime %></span>
                <% if (blog.views > 0) { %>
                <span aria-hidden="true" class="blog-post__dot">&middot;</span>
                <span><%= blog.views.toLocaleString() %> views</span>
                <% } %>
              </div>
            </div>
          </div>

          <div class="blog-post__share-icons" aria-label="Share this article">
            <button class="blog-share-btn" type="button" data-share="twitter" aria-label="Share on Twitter">
              <svg width="16" height="16" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true"><path d="M18.244 2.25h3.308l-7.227 8.26 8.502 11.24H16.17l-5.214-6.817L4.99 21.75H1.68l7.73-8.835L1.254 2.25H8.08l4.713 6.231zm-1.161 17.52h1.833L7.084 4.126H5.117z"/></svg>
            </button>
            <button class="blog-share-btn" type="button" data-share="linkedin" aria-label="Share on LinkedIn">
              <svg width="16" height="16" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true"><path d="M20.447 20.452h-3.554v-5.569c0-1.328-.027-3.037-1.852-3.037-1.853 0-2.136 1.445-2.136 2.939v5.667H9.351V9h3.414v1.561h.046c.477-.9 1.637-1.85 3.37-1.85 3.601 0 4.267 2.37 4.267 5.455v6.286zM5.337 7.433c-1.144 0-2.063-.926-2.063-2.065 0-1.138.92-2.063 2.063-2.063 1.14 0 2.064.925 2.064 2.063 0 1.139-.925 2.065-2.064 2.065zm1.782 13.019H3.555V9h3.564v11.452zM22.225 0H1.771C.792 0 0 .774 0 1.729v20.542C0 23.227.792 24 1.771 24h20.451C23.2 24 24 23.227 24 22.271V1.729C24 .774 23.2 0 22.222 0h.003z"/></svg>
            </button>
            <button class="blog-share-btn" type="button" data-share="copy" aria-label="Copy article link">
              <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M10 13a5 5 0 0 0 7.54.54l3-3a5 5 0 0 0-7.07-7.07l-1.72 1.71"/><path d="M14 11a5 5 0 0 0-7.54-.54l-3 3a5 5 0 0 0 7.07 7.07l1.71-1.71"/></svg>
            </button>
          </div>
        </div>

      </div>
    </div>
  </header>

  <%# ─── HERO IMAGE — full-width, prominent ─── %>
  <div class="blog-post-cover">
    <div class="container">
      <figure class="blog-post__cover-figure">
        <img
          src="<%= blog.thumbnail || '/images/blog/placeholder.svg' %>"
          alt="<%= blog.title %>"
          width="1000"
          height="560"
          loading="eager"
          fetchpriority="high"
          decoding="async"
          class="blog-post__cover-img"
          onerror="this.onerror=null;this.src='/images/blog/placeholder.svg'"
        >
      </figure>
    </div>
  </div>

  <%# ─── FLOATING TOC BAR ─── %>
  <div class="blog-toc-bar" id="blogTocBar" aria-label="Table of contents" hidden>
    <div class="container">
      <button class="blog-toc-bar__toggle" id="tocToggleBtn" aria-expanded="false" aria-controls="tocDropdown" type="button">
        <svg width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><line x1="8" y1="6" x2="21" y2="6"/><line x1="8" y1="12" x2="21" y2="12"/><line x1="8" y1="18" x2="21" y2="18"/><line x1="3" y1="6" x2="3.01" y2="6"/><line x1="3" y1="12" x2="3.01" y2="12"/><line x1="3" y1="18" x2="3.01" y2="18"/></svg>
        <span id="tocActiveLabel">Contents</span>
        <svg class="blog-toc-bar__chevron" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><polyline points="6 9 12 15 18 9"/></svg>
      </button>
    </div>
    <div class="blog-toc-bar__dropdown" id="tocDropdown" hidden>
      <div class="container">
        <nav class="blog-toc-dropdown__nav" data-blog-toc aria-label="Article sections"></nav>
      </div>
    </div>
  </div>

  <%# ─── ARTICLE BODY + SIDEBAR ─── %>
  <section class="blog-post-content" aria-label="Article content">
    <div class="container">
      <div class="blog-post-layout">

        <%# ─── MAIN ARTICLE ─── %>
        <article class="blog-article" aria-labelledby="blogArticleTitle">
          <h2 class="sr-only" id="blogArticleTitle">Article body</h2>

          <% if (adsensePubId && adsensePubId !== 'ca-pub-XXXXXXXXXXXXXXXXX') { %>
          <div class="ad-in-article" aria-label="Advertisement">
            <ins class="adsbygoogle"
                 style="display:block; text-align:center;"
                 data-ad-layout="in-article"
                 data-ad-format="fluid"
                 data-ad-client="<%= adsensePubId %>"
                 data-ad-slot="auto"></ins>
          </div>
          <% } %>

          <div class="blog-article__body" id="blogArticleBody">
            <%- article ? article.content : (blog ? blog.content : '') %>
          </div>

          <% if (adsensePubId && adsensePubId !== 'ca-pub-XXXXXXXXXXXXXXXXX') { %>
          <div class="ad-in-article" aria-label="Advertisement">
            <ins class="adsbygoogle"
                 style="display:block; text-align:center;"
                 data-ad-layout="in-article"
                 data-ad-format="fluid"
                 data-ad-client="<%= adsensePubId %>"
                 data-ad-slot="auto"></ins>
          </div>
          <% } %>

          <%# ─── TAGS ─── %>
          <% if (blog.tags && blog.tags.length > 0) { %>
          <div class="blog-post__footer-tags">
            <span class="blog-post__tags-label">Tagged:</span>
            <% blog.tags.forEach(function(tag) { %>
            <a href="/blog/?tag=<%= encodeURIComponent(tag) %>" class="blog-tag-link"><%= tag %></a>
            <% }); %>
          </div>
          <% } %>

          <%# ─── SHARE ROW (bottom) ─── %>
          <div class="blog-post__share-bottom">
            <p class="blog-post__share-label">Found this helpful? Share it:</p>
            <div class="blog-post__share-actions" aria-label="Share this article">
              <button class="blog-share-btn btn btn-secondary btn-sm" type="button" data-share="twitter" aria-label="Share on Twitter">
                <svg width="14" height="14" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true"><path d="M18.244 2.25h3.308l-7.227 8.26 8.502 11.24H16.17l-5.214-6.817L4.99 21.75H1.68l7.73-8.835L1.254 2.25H8.08l4.713 6.231zm-1.161 17.52h1.833L7.084 4.126H5.117z"/></svg>
                Share on X
              </button>
              <button class="blog-share-btn btn btn-secondary btn-sm" type="button" data-share="linkedin" aria-label="Share on LinkedIn">
                <svg width="14" height="14" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true"><path d="M20.447 20.452h-3.554v-5.569c0-1.328-.027-3.037-1.852-3.037-1.853 0-2.136 1.445-2.136 2.939v5.667H9.351V9h3.414v1.561h.046c.477-.9 1.637-1.85 3.37-1.85 3.601 0 4.267 2.37 4.267 5.455v6.286zM5.337 7.433c-1.144 0-2.063-.926-2.063-2.065 0-1.138.92-2.063 2.063-2.063 1.14 0 2.064.925 2.064 2.063 0 1.139-.925 2.065-2.064 2.065zm1.782 13.019H3.555V9h3.564v11.452zM22.225 0H1.771C.792 0 0 .774 0 1.729v20.542C0 23.227.792 24 1.771 24h20.451C23.2 24 24 23.227 24 22.271V1.729C24 .774 23.2 0 22.222 0h.003z"/></svg>
                LinkedIn
              </button>
              <button class="blog-share-btn btn btn-ghost btn-sm" type="button" data-share="copy" aria-label="Copy link">
                <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M10 13a5 5 0 0 0 7.54.54l3-3a5 5 0 0 0-7.07-7.07l-1.72 1.71"/><path d="M14 11a5 5 0 0 0-7.54-.54l-3 3a5 5 0 0 0 7.07 7.07l1.71-1.71"/></svg>
                Copy Link
              </button>
            </div>
          </div>

          <%# ─── PREV / NEXT ─── %>
          <nav class="blog-post-nav" aria-label="Previous and next articles">
            <% if (prevPost) { %>
            <a href="/blog/<%= prevPost.slug %>/" class="blog-post-nav__link blog-post-nav__link--prev">
              <span class="blog-post-nav__dir">← Previous</span>
              <span class="blog-post-nav__title"><%= prevPost.title %></span>
            </a>
            <% } else { %>
            <div></div>
            <% } %>
            <% if (nextPost) { %>
            <a href="/blog/<%= nextPost.slug %>/" class="blog-post-nav__link blog-post-nav__link--next">
              <span class="blog-post-nav__dir">Next →</span>
              <span class="blog-post-nav__title"><%= nextPost.title %></span>
            </a>
            <% } %>
          </nav>

        </article>

        <%# ─── SIDEBAR ─── %>
        <aside class="blog-sidebar blog-sidebar--post" aria-label="Article sidebar">

          <%# ─── NEWSLETTER ─── %>
          <div class="blog-widget blog-widget--newsletter">
            <div class="blog-widget__icon" aria-hidden="true">
              <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M4 4h16c1.1 0 2 .9 2 2v12c0 1.1-.9 2-2 2H4c-1.1 0-2-.9-2-2V6c0-1.1.9-2 2-2z"/><polyline points="22,6 12,13 2,6"/></svg>
            </div>
            <h3 class="blog-widget__title">Stay Updated</h3>
            <p class="blog-widget__desc">Get the latest dev articles delivered to your inbox. No spam, ever.</p>
            <a href="/newsletter/" class="btn btn-primary btn-sm blog-widget__cta">Subscribe Free →</a>
          </div>

          <%# ─── RELATED ARTICLES ─── %>
          <% if (relatedPosts && relatedPosts.length > 0) { %>
          <div class="blog-widget">
            <h3 class="blog-widget__title">Related Articles</h3>
            <ul class="blog-widget__related">
              <% relatedPosts.forEach(function(rp) { %>
              <li class="blog-widget__related-item">
                <a href="/blog/<%= rp.slug %>/">
                  <% if (rp.thumbnail) { %>
                  <img
                    class="blog-widget__related-thumb"
                    src="<%= rp.thumbnail %>"
                    alt=""
                    width="56"
                    height="42"
                    loading="lazy"
                    onerror="this.style.display='none'"
                  >
                  <% } %>
                  <div class="blog-widget__related-text">
                    <span class="blog-widget__related-title"><%= rp.title %></span>
                    <span class="blog-widget__related-date"><%= rp.formattedDate %></span>
                  </div>
                </a>
              </li>
              <% }); %>
            </ul>
          </div>
          <% } %>

          <% if (adsensePubId && adsensePubId !== 'ca-pub-XXXXXXXXXXXXXXXXX') { %>
          <div class="blog-widget blog-widget--ad" aria-label="Advertisement">
            <ins class="adsbygoogle"
                 style="display:block"
                 data-ad-client="<%= adsensePubId %>"
                 data-ad-slot="auto"
                 data-ad-format="auto"
                 data-full-width-responsive="true"></ins>
          </div>
          <% } %>

        </aside>

      </div>
    </div>
  </section>

  <% if (adsensePubId && adsensePubId !== 'ca-pub-XXXXXXXXXXXXXXXXX') { %>
  <div class="ad-leaderboard" aria-label="Advertisement">
    <ins class="adsbygoogle"
         style="display:block"
         data-ad-client="<%= adsensePubId %>"
         data-ad-slot="auto"
         data-ad-format="auto"
         data-full-width-responsive="true"></ins>
  </div>
  <% } %>

</div>
