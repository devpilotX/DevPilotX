<%- include('../partials/seo-head') %>
<%- include('../partials/header') %>

<div class="page-content">

  <section class="tool-hero" aria-label="Regex Builder">
    <div class="container">
      <div class="tool-hero-breadcrumb">
        <a href="/">Home</a>
        <span class="breadcrumb-sep" aria-hidden="true">/</span>
        <a href="/tools/">Tools</a>
        <span class="breadcrumb-sep" aria-hidden="true">/</span>
        <span aria-current="page">Regex Builder</span>
      </div>
      <div class="tool-hero-header">
        <div class="tool-hero-icon" aria-hidden="true">.*</div>
        <div class="tool-hero-text">
          <h1>Regex Builder</h1>
          <p class="tool-hero-desc">Build, test, and debug regular expressions with live matching, group highlighting, and code generation. 100&percnt; client-side &mdash; nothing leaves your machine.</p>
        </div>
      </div>
      <div class="tool-hero-badges">
        <span class="badge"><span class="badge-dot" aria-hidden="true"></span>Free Forever</span>
        <span class="badge-pill">Live Preview</span>
        <span class="badge-pill">No Server Processing</span>
      </div>
    </div>
  </section>
<!-- ========== ADSENSE: LEADERBOARD ========== -->
<% if (adsensePubId && adsensePubId !== 'ca-pub-XXXXXXXXXXXXXXXXX') { %>
<div class="ad-leaderboard" aria-label="Advertisement">
  <ins class="adsbygoogle"
       style="display:block"
       data-ad-client="<%= adsensePubId %>"
       data-ad-slot="auto"
       data-ad-format="auto"
       data-full-width-responsive="true"></ins>
  <script>(adsbygoogle = window.adsbygoogle || []).push({});</script>
</div>
<% } %>


  <section class="tool-workspace" aria-label="Regex workspace">
    <div class="container">
      <div class="regex-main">

        <!-- Pattern bar -->
        <div class="regex-pattern-bar" id="regex-pattern-bar">
          <label for="regex-input" class="sr-only">Regular expression pattern</label>
          <span class="regex-slash regex-slash-open" aria-hidden="true">/</span>
          <input
            type="text"
            id="regex-input"
            class="regex-input mono"
            placeholder="Enter regex, e.g. \\d{3}-\\d{4}"
            spellcheck="false"
            autocomplete="off"
            autocapitalize="off"
          >
          <span class="regex-slash regex-slash-close" aria-hidden="true">/</span>
          <div class="regex-flags" role="group" aria-label="Regex flags">
            <button type="button" class="flag-btn mono" data-flag="g" aria-pressed="true" title="Global (g)">g</button>
            <button type="button" class="flag-btn mono" data-flag="i" aria-pressed="false" title="Case-insensitive (i)">i</button>
            <button type="button" class="flag-btn mono" data-flag="m" aria-pressed="false" title="Multiline (m)">m</button>
            <button type="button" class="flag-btn mono" data-flag="s" aria-pressed="false" title="Dotall (s)">s</button>
            <button type="button" class="flag-btn mono" data-flag="u" aria-pressed="false" title="Unicode (u)">u</button>
          </div>
          <button type="button" class="btn btn-sm btn-secondary regex-clear-btn" id="regex-clear-btn" aria-label="Clear pattern and test string">
            <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><line x1="18" y1="6" x2="6" y2="18"/><line x1="6" y1="6" x2="18" y2="18"/></svg>
            <span>Clear</span>
          </button>
        </div>

        <!-- Status -->
        <div id="regex-status" class="regex-status regex-status-hidden" role="status" aria-live="polite">
          <span id="regex-status-icon" class="regex-status-icon" aria-hidden="true"></span>
          <span id="regex-status-text" class="regex-status-text"></span>
        </div>

        <!-- Test string -->
        <div class="regex-test-panel">
          <div class="regex-panel-header">
            <h2 class="regex-panel-title">Test String</h2>
            <div class="regex-panel-actions">
              <span id="match-count" class="regex-match-count mono" aria-live="polite">0 matches</span>
              <button type="button" class="btn btn-sm btn-ghost" id="regex-sample-btn" aria-label="Load sample text"><span>Load Sample</span></button>
            </div>
          </div>
          <div class="regex-test-wrap" id="regex-test-wrap">
            <div id="regex-highlight" class="regex-highlight mono" aria-hidden="true"></div>
            <textarea
              id="regex-test"
              class="regex-test mono"
              placeholder="Enter or paste test string here…"
              spellcheck="false"
              rows="8"
              aria-label="Test string input"
            ></textarea>
          </div>
        </div>

        <!-- Results grid -->
        <div class="regex-results-grid" aria-busy="false" id="regex-results-region">
          <div class="regex-panel regex-matches-panel">
            <div class="regex-panel-header">
              <h2 class="regex-panel-title">Match Details</h2>
            </div>
            <div id="regex-matches" class="regex-scroll-body" aria-label="Match results" role="log">
              <p class="regex-placeholder-msg">Enter a pattern and test string to see matches.</p>
            </div>
          </div>
          <div class="regex-panel regex-groups-panel">
            <div class="regex-panel-header">
              <h2 class="regex-panel-title">Capture Groups</h2>
            </div>
            <div id="regex-groups" class="regex-scroll-body" aria-label="Capture groups" role="log">
              <p class="regex-placeholder-msg">Groups appear when your pattern contains ( ).</p>
            </div>
          </div>
        </div>

        <!-- Replace -->
        <div class="regex-panel regex-replace-panel">
          <div class="regex-panel-header">
            <h2 class="regex-panel-title">Replace</h2>
            <button type="button" class="btn btn-sm btn-secondary" id="regex-copy-replaced" aria-label="Copy replaced text">
              <svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><rect x="9" y="9" width="13" height="13" rx="2" ry="2"/><path d="M5 15H4a2 2 0 0 1-2-2V4a2 2 0 0 1 2-2h9a2 2 0 0 1 2 2v1"/></svg>
              <span>Copy</span>
            </button>
          </div>
          <label for="regex-replace-input" class="sr-only">Replacement string</label>
          <input type="text" id="regex-replace-input" class="regex-replace-input mono" placeholder="Replacement, e.g. $1-$2" spellcheck="false" autocomplete="off">
          <pre id="regex-replace-output" class="regex-replace-output mono" aria-label="Replacement result"></pre>
        </div>

        <!-- Code generation -->
        <div class="regex-panel regex-codegen-panel">
          <div class="regex-panel-header">
            <h2 class="regex-panel-title">Code Generation</h2>
            <div class="regex-lang-wrap">
              <label for="regex-lang-select" class="sr-only">Language</label>
              <select id="regex-lang-select" class="regex-lang-select">
                <option value="javascript" selected>JavaScript</option>
                <option value="python">Python</option>
                <option value="java">Java</option>
                <option value="go">Go</option>
                <option value="php">PHP</option>
                <option value="csharp">C#</option>
                <option value="ruby">Ruby</option>
                <option value="rust">Rust</option>
              </select>
            </div>
            <button type="button" class="btn btn-sm btn-secondary" id="regex-copy-code" aria-label="Copy generated code">
              <svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><rect x="9" y="9" width="13" height="13" rx="2" ry="2"/><path d="M5 15H4a2 2 0 0 1-2-2V4a2 2 0 0 1 2-2h9a2 2 0 0 1 2 2v1"/></svg>
              <span>Copy</span>
            </button>
          </div>
          <pre id="regex-codegen-output" class="regex-codegen-output"><code id="regex-codegen-code"></code></pre>
        </div>

        <!-- Quick reference -->
        <div class="regex-panel regex-cheatsheet-panel">
          <div class="regex-panel-header">
            <h2 class="regex-panel-title">Quick Reference</h2>
            <button type="button" class="btn btn-sm btn-ghost regex-cheatsheet-toggle" id="regex-cheatsheet-toggle" aria-expanded="true" aria-controls="regex-cheatsheet-body">
              <span class="cheatsheet-toggle-text">Collapse</span>
              <svg class="cheatsheet-chevron" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><polyline points="6 9 12 15 18 9"/></svg>
            </button>
          </div>
          <div id="regex-cheatsheet-body" class="regex-cheatsheet-body">
            <div class="cheatsheet-grid">

              <div class="cheatsheet-col">
                <h3 class="cheatsheet-section-title">Character Classes</h3>
                <table class="cheatsheet-table" aria-label="Character classes"><tbody>
                  <tr><td class="mono ct">.</td><td>Any char except newline</td></tr>
                  <tr><td class="mono ct">\\d</td><td>Digit [0-9]</td></tr>
                  <tr><td class="mono ct">\\D</td><td>Non-digit</td></tr>
                  <tr><td class="mono ct">\\w</td><td>Word [a-zA-Z0-9_]</td></tr>
                  <tr><td class="mono ct">\\W</td><td>Non-word</td></tr>
                  <tr><td class="mono ct">\\s</td><td>Whitespace</td></tr>
                  <tr><td class="mono ct">\\S</td><td>Non-whitespace</td></tr>
                  <tr><td class="mono ct">[abc]</td><td>Character set</td></tr>
                  <tr><td class="mono ct">[^abc]</td><td>Negated set</td></tr>
                  <tr><td class="mono ct">[a-z]</td><td>Range</td></tr>
                </tbody></table>
              </div>

              <div class="cheatsheet-col">
                <h3 class="cheatsheet-section-title">Quantifiers</h3>
                <table class="cheatsheet-table" aria-label="Quantifiers"><tbody>
                  <tr><td class="mono ct">*</td><td>0 or more</td></tr>
                  <tr><td class="mono ct">+</td><td>1 or more</td></tr>
                  <tr><td class="mono ct">?</td><td>0 or 1</td></tr>
                  <tr><td class="mono ct">{n}</td><td>Exactly n</td></tr>
                  <tr><td class="mono ct">{n,}</td><td>n or more</td></tr>
                  <tr><td class="mono ct">{n,m}</td><td>Between n and m</td></tr>
                  <tr><td class="mono ct">*?</td><td>Lazy 0 or more</td></tr>
                  <tr><td class="mono ct">+?</td><td>Lazy 1 or more</td></tr>
                </tbody></table>
              </div>

              <div class="cheatsheet-col">
                <h3 class="cheatsheet-section-title">Anchors &amp; Groups</h3>
                <table class="cheatsheet-table" aria-label="Anchors and groups"><tbody>
                  <tr><td class="mono ct">^</td><td>Start of string/line</td></tr>
                  <tr><td class="mono ct">$</td><td>End of string/line</td></tr>
                  <tr><td class="mono ct">\\b</td><td>Word boundary</td></tr>
                  <tr><td class="mono ct">(abc)</td><td>Capture group</td></tr>
                  <tr><td class="mono ct">(?:abc)</td><td>Non-capture group</td></tr>
                  <tr><td class="mono ct">(?=abc)</td><td>Positive lookahead</td></tr>
                  <tr><td class="mono ct">(?!abc)</td><td>Negative lookahead</td></tr>
                  <tr><td class="mono ct">(?&lt;=abc)</td><td>Positive lookbehind</td></tr>
                  <tr><td class="mono ct">(?&lt;!abc)</td><td>Negative lookbehind</td></tr>
                  <tr><td class="mono ct">a|b</td><td>Alternation (or)</td></tr>
                </tbody></table>
              </div>

              <div class="cheatsheet-col">
                <h3 class="cheatsheet-section-title">Common Patterns</h3>
                <div class="cheatsheet-patterns" id="cheatsheet-patterns"></div>
              </div>

            </div>
          </div>
        </div>

      </div>
    </div>
  </section>

  <section class="content-section" aria-label="Related tools">
    <div class="section-header">
      <span class="section-number" aria-hidden="true">[&rarr;]</span>
      <h2>Related Tools</h2>
    </div>
    <p class="section-desc">More tools you might find useful.</p>
    <div class="tools-grid tools-grid-3">
      <a href="/tools/json-formatter" class="tool-card">
        <span class="tool-card-icon" aria-hidden="true">{ }</span>
        <h3 class="tool-card-name">JSON Formatter</h3>
        <p class="tool-card-desc">Format, validate, and minify JSON instantly.</p>
        <span class="tool-card-arrow" aria-hidden="true">Open &rarr;</span>
      </a>
      <a href="/tools/diff-checker" class="tool-card">
        <span class="tool-card-icon" aria-hidden="true">&hArr;</span>
        <h3 class="tool-card-name">Diff Checker</h3>
        <p class="tool-card-desc">Compare text or code side by side.</p>
        <span class="tool-card-arrow" aria-hidden="true">Open &rarr;</span>
      </a>
      <a href="/tools/code-formatter" class="tool-card">
        <span class="tool-card-icon" aria-hidden="true">&starf;</span>
        <h3 class="tool-card-name">Code Formatter</h3>
        <p class="tool-card-desc">Beautify and format code in multiple languages.</p>
        <span class="tool-card-arrow" aria-hidden="true">Open &rarr;</span>
      </a>
    </div>
  </section>

</div>

<%- include('../partials/tool-faq') %>
<%- include('../partials/footer') %>