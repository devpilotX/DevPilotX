<%# ============================================================ %>
<%# Value.Codes — 404 Not Found Error Page                      %>
<%# ============================================================ %>

<% /* Use the main layout */ %>
<section class="error-page" aria-label="Page not found">
  <div class="error-container">

    <!-- ========== ERROR CODE ========== -->
    <div class="error-code" aria-hidden="true">404</div>

    <!-- ========== ERROR MESSAGE ========== -->
    <h1 class="error-title">Page Not Found</h1>
    <p class="error-description">The page you are looking for does not exist, has been moved, or is temporarily unavailable.</p>

    <!-- ========== HELPFUL LINKS ========== -->
    <div class="error-actions">
      <a href="/" class="btn btn-primary">Go to Homepage</a>
      <a href="/tools" class="btn btn-secondary">Browse Tools</a>
    </div>

    <!-- ========== SUGGESTIONS ========== -->
    <div class="error-suggestions">
      <p class="error-suggestions-title">Here are some helpful links:</p>
      <ul class="error-links">
        <li><a href="/tools">Developer Tools</a></li>
        <li><a href="/compiler">Online Compiler</a></li>
        <li><a href="/community">Community</a></li>
        <li><a href="/blog">Blog</a></li>
        <li><a href="/resources">Resources</a></li>
        <li><a href="/contact">Contact Us</a></li>
      </ul>
    </div>

  </div>
</section>
