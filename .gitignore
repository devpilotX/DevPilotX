# ============================================================
# Value.Codes — Git Ignore Rules
# ============================================================

# ------------------------------------------------------------
# Dependencies
# ------------------------------------------------------------
node_modules/

# ------------------------------------------------------------
# Environment variables (contains secrets)
# ------------------------------------------------------------
.env

# ------------------------------------------------------------
# OS generated files
# ------------------------------------------------------------
.DS_Store
Thumbs.db
desktop.ini
*.swp
*.swo
*~

# ------------------------------------------------------------
# IDE / Editor files
# ------------------------------------------------------------
.vscode/
.idea/
*.sublime-project
*.sublime-workspace

# ------------------------------------------------------------
# Logs
# ------------------------------------------------------------
logs/
*.log
npm-debug.log*

# ------------------------------------------------------------
# Runtime / Build
# ------------------------------------------------------------
tmp/
temp/
.cache/

# ------------------------------------------------------------
# Uploaded files (if any user uploads are added later)
# ------------------------------------------------------------
uploads/
